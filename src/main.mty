fn welcome_recent_folder_base() -> I32 { 2000 }

// Hit-test the click against the Welcome layout, but only when the Welcome
// screen actually owns the body (`owns == 1`); otherwise -1 so the normal click
// routing runs. Pure shim call (no caller-local writes, so it factors cleanly).
fn welcome_click_action(h: I64, owns: I32) -> I32 {
  if owns == 1 {
    mui_welcome_click(h)
  } else {
    -1
  }
}

