  fn mui_def_target_col(handle: I64) -> I32
  fn mui_def_open_target(handle: I64) -> I32
  // ---- undo / redo (Feature A): shim-owned history (snapshots live shim-side) ----
  // Mighty streams its post-edit buffer in (like save), the shim coalesces typing
  // runs + decides whether to push. seed on load/switch; break on non-insert
  // boundaries; record after each edit-group. undo/redo restore into load_buf,
  // which Mighty pulls via mui_load_byte; the cursor comes back as scalars.
  fn mui_undo_seed_begin(handle: I64)
  fn mui_undo_seed_byte(handle: I64, byte: I32)
  fn mui_undo_seed_commit(handle: I64, cur_line: I32, cur_col: I32)
  fn mui_undo_break(handle: I64)
  fn mui_undo_record_begin(handle: I64)
  fn mui_undo_record_byte(handle: I64, byte: I32)
  fn mui_undo_record_commit(handle: I64, cur_line: I32, cur_col: I32) -> I32
  fn mui_undo(handle: I64) -> I32
  fn mui_redo(handle: I64) -> I32
  fn mui_undo_cursor_line(handle: I64) -> I32
  fn mui_undo_cursor_col(handle: I64) -> I32
  fn mui_undo_depth(handle: I64) -> I32
  fn mui_redo_depth(handle: I64) -> I32
  // ---- format document (Feature B): runs `mty fmt <path>` in place ----
  fn mui_format_current(handle: I64) -> I32
  // ---- command palette (Ctrl+Shift+P): shim-side registry + filtering ----
  // Mighty opens the palette, routes Char/Backspace/Up/Down/Enter/Escape to it,
  // and on Enter reads the selected command id back to dispatch to the SAME
  // helper the keybinding triggers. The command Vec + filter + selection live
  // shim-side (L21: Mighty never holds the command list).
  fn mui_palette_open(handle: I64)
