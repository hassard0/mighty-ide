  fn mui_term_rows(handle: I64) -> I32
  fn mui_term_cols(handle: I64) -> I32
  fn mui_term_draw(handle: I64)
  fn mui_log_terminal(handle: I64)
  // ---- autocomplete dropdown (sub-project 6): shim-side engine ----
  // Mighty streams the buffer in (like find), requests completion at (line,col),
  // then drives the dropdown via scalar getters/movers and reads the accepted
  // text back to insert. The candidate list + selection live shim-side (L21:
  // Mighty never holds the candidate Vec).
  fn mui_complete_reset(handle: I64)
  fn mui_complete_push_byte(handle: I64, byte: I32)
  fn mui_complete_request(handle: I64, line: I32, col: I32) -> I32
  fn mui_complete_count(handle: I64) -> I32
  fn mui_complete_active(handle: I64) -> I32
  fn mui_complete_sel(handle: I64) -> I32
  fn mui_complete_move(handle: I64, delta: I32)
  fn mui_complete_prefix_len(handle: I64) -> I32
  fn mui_complete_accept_len(handle: I64) -> I32
  fn mui_complete_accept_char(handle: I64, i: I32) -> I32
  fn mui_complete_cancel(handle: I64)
  fn mui_complete_draw_at(handle: I64, row: I32, col: I32, total_lines: I32)
  // ---- hover + go-to-definition (sub-project 7): shim-side LSP nav ----
  // Mighty streams the buffer in (like completion/find), requests hover/def at
  // (line,col) 0-based, then reads scalars back. The hover popup + the resolved
  // definition target live shim-side (L21: Mighty never holds the result Vec).
  fn mui_nav_reset(handle: I64)
  fn mui_nav_push_byte(handle: I64, byte: I32)
  fn mui_hover_request(handle: I64, line: I32, col: I32) -> I32
