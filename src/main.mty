fn cmd_git_first() -> I32 { 26 } // Git: Switch Branch (lowest git id)
fn cmd_git_last() -> I32 { 30 }  // Git: Toggle Blame (highest git id)
fn cmd_run_in_browser() -> I32 { 31 } // Mighty: Run in Browser (wasm32-web)
// Editor split-pane commands route to the single `mui_pane_dispatch` shim entry
// (same one-arm-range pattern as git — keeps the palette ladder flat, L37/L38).
