fn cmd_pane_last() -> I32 { 35 }  // Markdown: Open Preview (highest pane id)

// Workspace / Open-Folder commands route to the single `mui_ws_dispatch` shim
// entry (same one-arm-range pattern as git/pane — keeps the ladder flat).
fn cmd_ws_first() -> I32 { 36 } // File: Open Folder (lowest ws id)
fn cmd_ws_last() -> I32 { 37 }  // File: Open Recent (highest ws id)
fn cmd_keyboard_shortcuts() -> I32 { 38 } // Help: Keyboard Shortcuts overlay
// Code-folding commands route to the single `mui_fold_dispatch` shim entry so
// the palette ladders gain ONE arm range, not three (L37/L38).
fn cmd_fold_first() -> I32 { 39 } // Fold: Toggle at Cursor (lowest fold id)
fn cmd_fold_last() -> I32 { 41 }  // Fold: Unfold All (highest fold id)
