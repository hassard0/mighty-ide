  fn mui_prompt_draw(handle: I64)
  // feature 3: go-to-line
  fn mui_prompt_goto_target(handle: I64) -> I32
  // feature 4: find (stream buffer in, search shim-side, read matches back)
  fn mui_find_reset(handle: I64)
  fn mui_find_push_byte(handle: I64, byte: I32)
  fn mui_find_run(handle: I64) -> I32
  fn mui_find_count(handle: I64) -> I32
  fn mui_find_match_line(handle: I64, i: I32) -> I32
  fn mui_find_match_col(handle: I64, i: I32) -> I32
  fn mui_find_match_offset(handle: I64, i: I32) -> I32
  fn mui_find_needle_len(handle: I64) -> I32
  fn mui_find_highlight_row(handle: I64, row: I32, col_start: I32, len: I32, total_lines: I32)
  // ---- multi-file workspace (sub-project 4): tabs + file tree + sidebar ----
  // path staging (reused from load/save) for Ctrl+O open-by-path
  fn mui_path_clear(handle: I64)
  fn mui_path_push(handle: I64, byte: I32)
  // tab store
  fn mui_tab_count(handle: I64) -> I32
  fn mui_tab_active(handle: I64) -> I32
  fn mui_tab_open_path(handle: I64) -> I32
  fn mui_tab_switch(handle: I64, idx: I32) -> I32
  fn mui_tab_next(handle: I64) -> I32
  fn mui_tab_prev(handle: I64) -> I32
  fn mui_tab_close(handle: I64, idx: I32) -> I32
  fn mui_tab_index_at_click(handle: I64) -> I32
  fn mui_tab_store_begin(handle: I64, idx: I32)
  fn mui_tab_store_byte(handle: I64, idx: I32, byte: I32)
  fn mui_tab_store_commit(handle: I64, idx: I32, cursor_line: I32, cursor_col: I32, scroll_first: I32)
  fn mui_tab_set_dirty(handle: I64, idx: I32, dirty: I32)
  fn mui_tab_load(handle: I64, idx: I32) -> I64
  fn mui_tab_load_into(handle: I64, idx: I32) -> I64
  fn mui_tab_load_byte(handle: I64, idx: I32, i: I64) -> I32
  fn mui_tab_cursor_line(handle: I64, idx: I32) -> I32
  fn mui_tab_cursor_col(handle: I64, idx: I32) -> I32
  fn mui_tab_scroll(handle: I64, idx: I32) -> I32
  fn mui_tab_bar_draw(handle: I64)
  // file-tree sidebar
  fn mui_sidebar_visible(handle: I64) -> I32
  fn mui_sidebar_toggle(handle: I64) -> I32
  fn mui_sidebar_draw(handle: I64)
  fn mui_tree_refresh(handle: I64) -> I32
  fn mui_tree_count(handle: I64) -> I32
  fn mui_tree_is_dir(handle: I64, i: I32) -> I32
  fn mui_tree_depth(handle: I64, i: I32) -> I32
  fn mui_tree_is_expanded(handle: I64, i: I32) -> I32
  fn mui_tree_toggle(handle: I64, i: I32) -> I32
  fn mui_tree_row_at_click(handle: I64) -> I32
  fn mui_tree_open_row(handle: I64, i: I32) -> I32
  // stdout evidence (computed counts; Mighty `log` is literal-only, L1)
  fn mui_log_workspace(handle: I64)
  // buffer-accumulation probe: prints the live Mighty buf.len() next to the
  // shim's own load byte count, to verify the real-arena runtime fix (L28).
  fn mui_probe_buf_len(handle: I64, mty_buf_len: I32)
  // ---- integrated terminal (sub-project 5): all logic shim-side ----
  // Mighty only toggles the panel, routes focused keystrokes, and per frame
  // calls pump + draw. The PTY/VT grid live entirely in the shim (L21: Mighty
  // never touches the terminal grid Vec).
  fn mui_term_open(handle: I64) -> I32
  fn mui_term_close(handle: I64)
  fn mui_term_running(handle: I64) -> I32
  fn mui_term_is_open(handle: I64) -> I32
  fn mui_term_key(handle: I64, keycode: I32, mods: I32)
  fn mui_term_send_codepoint(handle: I64, codepoint: I32, mods: I32)
  fn mui_term_send_byte(handle: I64, byte: I32)
