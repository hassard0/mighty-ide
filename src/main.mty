fn test_tb_stop() -> I32 { 2 }

// Chord predicates spelled as flat boolean expressions (no juxtaposed parens,
// L20) so native codegen accepts them.
fn is_z_key(cp: I32) -> Bool { cp == 122 || cp == 90 }      // 'z' / 'Z'
fn is_y_key(cp: I32) -> Bool { cp == 121 || cp == 89 }      // 'y' / 'Y'
fn is_i_key(cp: I32) -> Bool { cp == 105 || cp == 73 }      // 'i' / 'I'
fn is_p_key(cp: I32) -> Bool { cp == 112 || cp == 80 }      // 'p' / 'P'
fn is_f_key(cp: I32) -> Bool { cp == 102 || cp == 70 }      // 'f' / 'F'
fn is_g_key(cp: I32) -> Bool { cp == 103 || cp == 71 }      // 'g' / 'G'

fn is_search_panel_chord(cp: I32, mods: I32) -> Bool {      // Ctrl+Shift+F
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let f = is_f_key(cp)
  ctrl && shift && f
}

fn is_scm_panel_chord(cp: I32, mods: I32) -> Bool {         // Ctrl+Shift+G
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let g = is_g_key(cp)
  ctrl && shift && g
}

fn is_palette_chord(cp: I32, mods: I32) -> Bool {
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let p = is_p_key(cp)
  ctrl && shift && p
}

fn is_quickopen_chord(cp: I32, mods: I32) -> Bool {      // Ctrl+P (no Shift)
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let p = is_p_key(cp)
  ctrl && p && !shift
}

fn is_undo_chord(cp: I32, mods: I32) -> Bool {           // Ctrl+Z (no Shift)
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let z = is_z_key(cp)
  ctrl && z && !shift
}

fn is_redo_chord(cp: I32, mods: I32) -> Bool {           // Ctrl+Y or Ctrl+Shift+Z
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let y = is_y_key(cp)
  let z = is_z_key(cp)
  let shift_z = z && shift
  let any = y || shift_z
  ctrl && any
}

fn is_format_chord(cp: I32, mods: I32) -> Bool {         // Ctrl+Shift+I
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let i = is_i_key(cp)
  ctrl && shift && i
}

// True if the shift bit (value 1) is set in `mods`.
fn shift_held(mods: I32) -> Bool {
  let half = mods / 2
  let even = half * 2
  let bit = mods - even
  bit == 1
}

// True if the ctrl bit (value 2) is set in `mods` (parity of mods/2; no `%`).
fn ctrl_held(mods: I32) -> Bool {
  let half = mods / 2
  let quarter = half / 2
  let even = quarter * 2
  let bit = half - even
  bit == 1
}

// True if the alt bit (value 4) is set in `mods` (parity of mods/4; no `%`).
fn alt_held(mods: I32) -> Bool {
  let quarter = mods / 4
  let eighth = quarter / 2
  let even = eighth * 2
  let bit = quarter - even
  bit == 1
}

// Convert a Bool to the I32 extend-flag the *_ext shim ops expect.
fn ext_flag(b: Bool) -> I32 {
  if b { 1 } else { 0 }
}

fn is_d_key(cp: I32) -> Bool { cp == 100 || cp == 68 }     // 'd' / 'D'
fn is_h_key(cp: I32) -> Bool { cp == 104 || cp == 72 }     // 'h' / 'H'
fn is_a_key(cp: I32) -> Bool { cp == 97 || cp == 65 }      // 'a' / 'A'

fn is_ai_panel_chord(cp: I32, mods: I32) -> Bool {         // Ctrl+Shift+A : AI panel
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let a = is_a_key(cp)
  ctrl && shift && a
}

fn is_inline_ask_chord(cp: I32, mods: I32) -> Bool {       // Ctrl+I : inline ask
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let i = is_i_key(cp)
  ctrl && i && !shift
}

// Ctrl+D (add caret) or Ctrl+Shift+D (duplicate) — one chord, dispatched on
// shift at the call site. Alt must NOT be held (that's reserved). Folding both
// into one arm keeps the editor's giant if/else ladder shallow enough for the
// mty compiler's recursive-descent stack.
fn is_d_chord(cp: I32, mods: I32) -> Bool {
  let ctrl = ctrl_held(mods)
  let alt = alt_held(mods)
  let d = is_d_key(cp)
  ctrl && d && !alt
}

fn is_r_key(cp: I32) -> Bool { cp == 114 || cp == 82 }     // 'r' / 'R'

fn is_run_chord(cp: I32, mods: I32) -> Bool {              // Ctrl+Shift+R : run file
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let r = is_r_key(cp)
  ctrl && shift && r
}

fn is_replace_chord(cp: I32, mods: I32) -> Bool {          // Ctrl+H
  let ctrl = ctrl_held(mods)
  let h = is_h_key(cp)
  ctrl && h
}

// Alt+<char> with NO Ctrl. The single editor-ladder arm for ALL Alt chords;
// the actual chord (Alt+\ ghost, Alt+Z zen, …) is dispatched by the shim's
// `mui_chord` router so new chords never need a new top-level `else if` arm
// (L37 — the ladder is at the mty v0.36 parse-stack ceiling).
fn is_alt_chord(cp: I32, mods: I32) -> Bool {
  let alt = alt_held(mods)
  let ctrl = ctrl_held(mods)
  alt && !ctrl
}

// Chords routed to the shim `mui_chord` dispatcher from the SINGLE existing
// router arm (L37/L38: no new top-level editor-ladder arm). This is the Alt
// chords PLUS the split-pane Ctrl chords (Ctrl+\ split, Ctrl+1/Ctrl+2 focus).
// `mui_chord` returns 0 (unhandled) for a Ctrl+1/2 with no matching pane, so the
// arm is a safe no-op then.
// Forwards a chord to the shim `mui_chord` router (Alt chords + split-pane Ctrl
// chords + the fixed Ctrl+Shift defaults Markdown-preview/Open-Folder + the
// Shortcuts overlay). The router resolves REMAPS internally via its override map;
// since remap TARGETS are constrained to the Alt+<key> class (all forwarded here,
// none with another ladder binding), a remapped command's new chord always
// reaches the router. The router returns 0 for unrecognized chords and the caller
// ignores the return, so a forwarded-but-unhandled Alt chord is a harmless no-op.
fn is_router_chord(cp: I32, mods: I32) -> Bool {
  let alt = alt_held(mods)
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  if alt && !ctrl {
    true
  } else if ctrl && !alt && cp == 92 {     // Ctrl+\ : Split Editor Right
    true
  } else if ctrl && !alt && (cp == 49 || cp == 50) {  // Ctrl+1 / Ctrl+2 : focus pane
    true
  } else if ctrl && shift && !alt && (cp == 86 || cp == 118) {  // Ctrl+Shift+V : Markdown preview
    true
  } else if ctrl && shift && !alt && (cp == 79 || cp == 111) {  // Ctrl+Shift+O : Open Folder
    true
  } else if ctrl && shift && !alt && cp == 47 {  // Ctrl+Shift+/ : Keyboard Shortcuts overlay
    true
  } else {
    false
  }
}

fn is_t_key(cp: I32) -> Bool { cp == 116 || cp == 84 }     // 't' / 'T'

fn is_run_tests_chord(cp: I32, mods: I32) -> Bool {        // Ctrl+Shift+T : run tests
  let ctrl = ctrl_held(mods)
  let shift = shift_held(mods)
  let t = is_t_key(cp)
  ctrl && shift && t
}

// USize -> I32 without an `as` cast (L19): count up in an I32 accumulator.
fn usize_to_i32(u: USize) -> I32 {
  let mut n: I32 = 0
  let mut i: USize = 0
  while i < u {
    n = n + 1
    i = i + 1
  }
  n
}

// I32 -> USize without an `as` cast (L19): count up in a USize accumulator.
fn i32_to_usize(n: I32) -> USize {
  let mut u: USize = 0
  let mut i: I32 = 0
  while i < n {
    u = u + 1
    i = i + 1
  }
  u
}

// Clamp the scroll `first` so the cursor line stays on screen given `rows`
// visible rows. Pure integer math over the model's reported cursor line.
fn scroll_to_cursor(first: I32, cursor_line: I32, rows: I32) -> I32 {
  let mut top = first
  if cursor_line < top {
    top = cursor_line
  } else if cursor_line >= top + rows {
    top = cursor_line + 1 - rows
  }
  top
}

// ---- diagnostics overlay ----
//
// The diag set lives shim-side (it ran `mty check` and parsed the report); we
// read it back through scalar getters, so this is a FLAT `while d < count` loop
// with no Mighty Vec read inside. For each diag on a visible row we draw a small
// gutter dot + an underline (red error / amber warning) under its span.
fn count_errors(h: I64) -> I32 {
  let total = mui_diag_count(h)
  let mut errs: I32 = 0
  let mut d: I32 = 0
  while d < total {
    if mui_diag_severity(h, d) == 0 { errs = errs + 1 }
    d = d + 1
  }
  errs
}

fn draw_diagnostics(h: I64, total_lines_i: I32, first_i: I32, rows_i: I32) {
  let last_i = first_i + rows_i        // exclusive screen-line bound
  let count = mui_diag_count(h)
  let mut d: I32 = 0
  while d < count {
    let dline = mui_diag_line(h, d)
    if dline >= first_i && dline < last_i {
      let row = dline - first_i
      let cs = mui_diag_col_start(h, d)
      let ce = mui_diag_col_end(h, d)
      let sev = mui_diag_severity(h, d)
      if sev == 0 {
        // error: red (#F2545B)
        mui_diag_gutter_mark(h, row, 0.949_f32, 0.329_f32, 0.357_f32, 1.0_f32)
        mui_underline_row(h, row, cs, ce, total_lines_i, 0.949_f32, 0.329_f32, 0.357_f32, 1.0_f32)
      } else {
        // warning: amber (#E5B567)
        mui_diag_gutter_mark(h, row, 0.898_f32, 0.710_f32, 0.404_f32, 1.0_f32)
        mui_underline_row(h, row, cs, ce, total_lines_i, 0.898_f32, 0.710_f32, 0.404_f32, 1.0_f32)
      }
    }
    d = d + 1
  }
}

// Status bar: feed the 1-based cursor line/col + error count; the shim composes
// + draws the segmented status (filename / Ln,Col / diagnostics chip).
fn draw_status_bar(h: I64) {
  let errs = count_errors(h)
  let line1 = mui_ed_cursor_line(h) + 1
  let col1 = mui_ed_cursor_col(h) + 1
  mui_status_set_cursor(h, line1, col1)
  mui_status_render(h, errs)
}

// Highlight every find match that falls on a visible row. Matches live shim-side
// (FLAT `while m < count` loop, no Mighty Vec read in the body).
fn draw_find_highlights(h: I64, total_lines_i: I32, first_i: I32, rows_i: I32) {
  let last_i = first_i + rows_i
  let needle_len = mui_find_needle_len(h)
  let count = mui_find_count(h)
  let mut m: I32 = 0
  while m < count {
    let mline = mui_find_match_line(h, m)
    if mline >= first_i && mline < last_i {
      let row = mline - first_i
      let mcol = mui_find_match_col(h, m)
      mui_find_highlight_row(h, row, mcol, needle_len, total_lines_i)
    }
    m = m + 1
  }
}

// Jump the cursor to find match `idx` (0-based). No-op if out of range.
fn jump_to_match(h: I64, idx: I32) {
  let count = mui_find_count(h)
  if idx >= 0 && idx < count {
    let mline = mui_find_match_line(h, idx)
    let mcol = mui_find_match_col(h, idx)
    mui_ed_move_to(h, mline, mcol)
  }
}

fn main() {
  log("mighty-ide: starting")
  let h = mui_init_s(1280, 832)
  if h == 0 {
    log("mighty-ide: mui_init_s failed")
    return
  }
  // The shim opened argv[1] as tab 0 with its model populated from disk; load
  // it into the active model (resets cursor to top) and seed undo history.
  let _n0 = mui_ed_load(h)
  mui_ed_undo_reset(h)
  log("mighty-ide: buffer ready")

  // Workspace wiring evidence for non-interactive runs (shim prints counts;
  // Mighty native `log` is literal-only, L23).
  mui_log_workspace(h)

  // Initial diagnostics pass on the on-disk file.
  let dn = mui_diag_refresh(h)
  if dn == 0 { log("mighty-ide: diagnostics clean") } else { log("mighty-ide: diagnostics found") }
  // Initial document-symbol scan so the Outline panel + breadcrumb symbol
  // segment are populated from the first frame.
  let _on = mui_outline_refresh(h)

  let mut running = true
  let mut frame: I32 = 0
  // 0 for a normal interactive launch (run forever until the window Close
  // event); a positive cap only when a headless/screenshot/probe env is set, so
  // non-interactive captures/tests still exit. Gated shim-side (mui_headless_frames).
  let headless_limit: I32 = mui_headless_frames()

  // prompt_kind: 0 = none, 1 = goto, 2 = find, 3 = open (mirrors the shim).
  let mut prompt_kind: I32 = 0
  // In-file find/replace bar (Ctrl+H) active: keys route to its two fields.
  let mut replacing = false
  // After a successful Find, `find_nav` is true and `find_idx` is the current
  // match; Enter / 'n' advance, Escape / any edit clears. Matches live shim-side.
  let mut find_nav = false
  let mut find_idx: I32 = 0

  // Integrated terminal focus: when true, Char/Key route to the shell.
  let mut term_focus = false
  // Autocomplete dropdown open.
  let mut completing = false
  // Signature-help popup shown; anchored to the cursor cell it opened at.
  let mut sig_open = false
  let mut sig_line: I32 = 0
  let mut sig_col: I32 = 0
  // Rename inline input active (F2): keys route to the new-name buffer.
  let mut renaming = false
  let mut rename_line: I32 = 0
  let mut rename_col: I32 = 0
  // Code-action menu open (Ctrl+.): keys route to the menu.
  let mut code_action_open = false
  let mut ca_line: I32 = 0
  let mut ca_col: I32 = 0
  // Hover popup shown; anchored to a cursor cell (line, col).
  let mut hovering = false
  let mut hover_line: I32 = 0
  let mut hover_col: I32 = 0
  // One previous location for jump-back (Ctrl+Minus).
  let mut have_prev = false
  let mut prev_line: I32 = 0
  let mut prev_col: I32 = 0
  // AI copilot panel focused: Char/Key route to its multi-line input.
  let mut ai_focus = false
  // Command palette open.
  let mut palette_open = false
  // Universal Quick-Open (Ctrl+P) overlay open: keys route to the finder.
  let mut quickopen_open = false
  // Color-theme picker open (Preferences: Color Theme).
  let mut theme_picker_open = false
  // Run panel focused (Run rail icon / Ctrl+Shift+R): keys route to it (scroll).
  let mut run_focus = false
  // Web Playground focused (Run in Browser / Alt+W): keys route to it (scroll /
  // esc unfocus / click Stop+Open).
  let mut web_focus = false
  // Test panel focused (beaker rail icon / Ctrl+Shift+T): keys route to it.
  let mut test_focus = false
  // Settings panel open (Preferences: Settings / Ctrl+,).
  let mut settings_open = false
  // Inline git diff view open (Source Control): keys route to it (scroll/close).
  let mut diff_open = false
  // Branch switcher overlay open (Git: Switch Branch / status-bar branch click):
  // keys route to the picker (filter / move / Enter checkout / Esc cancel).
  let mut branch_open = false
  // First visible line (scroll); pushed to the model each frame. Initialized
  // from the model so a seeded scroll (e.g. the MUI_STICKY_AUTOOPEN screenshot
  // hook) survives the first frame instead of being reset to the top.
  let mut first: I32 = mui_ed_first_visible(h)
  // True while a contiguous typing run is in progress (so one Ctrl+Z undoes a
  // run, not one char). An undo checkpoint is recorded at the START of a run.
  let mut typing = false

  while running {
    let rows_i = mui_visible_rows(h)

    let mut tag = mui_poll_event_s(h)
    while tag != 0 && running {
      let mut command_click_id: I32 = -1
      if tag == ev_close() {
        running = false
      } else if mui_keys_active(h) == 1 || mui_crumb_menu_active(h) == 1 || mui_branch_active(h) == 1 {
        // THREE overlays share this ONE top-level arm (NESTED, not new sibling
        // arms — L37): the keyboard-shortcuts overlay, the breadcrumb dropdown,
        // and the git branch switcher. Folding them here keeps the editor key
        // ladder at its mty-parse-stack ceiling (no new top-level `else if`).
        if mui_keys_active(h) == 1 {
          // -------- keyboard shortcuts overlay --------------------------------
          // While capturing a new chord, ANY key (char or key event) is recorded
          // as the chord via `mui_keys_capture_chord` (cp + the current mods); Esc
          // cancels capture. Otherwise: type to filter, Up/Down move, Enter begins
          // capture for the selected (remappable) row, Ctrl+R resets one,
          // Ctrl+Shift+R resets all, Esc closes.
          let capturing = mui_keys_capturing(h)
          if capturing == 1 {
            let mods = mui_event_mods(h)
            if tag == ev_char() {
              let cp = mui_event_codepoint(h)
              let _r = mui_keys_capture_chord(h, cp, mods)
          } else if tag == ev_key() {
            let k = mui_event_key(h)
            if k == key_escape() {
              mui_keys_cancel(h)
            }
          } else if tag == ev_mouse_down() {
            mui_keys_cancel(h)
          }
        } else if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          let mods = mui_event_mods(h)
            let ctrl = ctrl_held(mods)
            let shift = shift_held(mods)
            let alt = alt_held(mods)
            let rk = is_r_key(cp)
            if ctrl && shift && rk {
              mui_keys_reset_all(h)
            } else if ctrl && rk {
              let _r = mui_keys_reset(h)
            } else if !ctrl && !alt && cp >= 32 && cp < 127 {
              mui_keys_push_char(h, cp)
            }
          } else if tag == ev_key() {
            let k = mui_event_key(h)
            if k == key_backspace() {
              mui_keys_backspace(h)
            } else if k == key_up() {
              mui_keys_move(h, -1)
            } else if k == key_down() {
              mui_keys_move(h, 1)
            } else if k == key_enter() {
              let _c = mui_keys_begin_capture(h)
            } else if k == key_escape() {
              mui_keys_cancel(h)
            }
          } else if tag == ev_mouse_down() {
            let kh = mui_keys_click(h)
            if kh >= 0 {
              let _c = mui_keys_begin_capture(h)
            } else {
              mui_keys_cancel(h)
            }
          }
        } else if mui_branch_active(h) == 1 {
          // -------- branch switcher: filter/type, move, Enter checkout, Esc ----
          if tag == ev_char() {
            let cp = mui_event_codepoint(h)
            if cp >= 32 && cp < 127 { mui_branch_push_char(h, cp) }
          } else if tag == ev_key() {
            let k = mui_event_key(h)
            if k == key_backspace() {
              mui_branch_backspace(h)
            } else if k == key_up() {
              mui_branch_move(h, -1)
            } else if k == key_down() {
              mui_branch_move(h, 1)
            } else if k == key_enter() {
              // Accept: 1 = checked-out/created (close), 2 = entered create mode
              // (stay open for the name), 0 = failed (stay open).
              let acc = mui_branch_accept(h)
              if acc == 1 {
                branch_open = false
                find_nav = false
                let _r = mui_diag_refresh(h)
                let _o = mui_outline_refresh(h)
              }
            } else if k == key_escape() {
              mui_branch_cancel(h)
              branch_open = false
            }
          } else if tag == ev_mouse_down() {
            let bh = mui_branch_click(h)
            if bh >= 0 {
              let acc = mui_branch_accept(h)
              if acc == 1 {
                branch_open = false
                find_nav = false
                let _r = mui_diag_refresh(h)
                let _o = mui_outline_refresh(h)
              }
            } else {
              mui_branch_cancel(h)
              branch_open = false
            }
          }
        } else {
          // -------- breadcrumb dropdown: navigate / accept / dismiss ----------
          if tag == ev_key() {
            let k = mui_event_key(h)
            if k == key_up() {
              mui_crumb_menu_move(h, -1)
            } else if k == key_down() {
              mui_crumb_menu_move(h, 1)
            } else if k == key_enter() {
              let _acc = mui_crumb_menu_accept(h, -1)
              mui_ed_undo_reset(h)
              find_nav = false
              let _r = mui_diag_refresh(h)
              let _o = mui_outline_refresh(h)
            } else if k == key_escape() {
              mui_crumb_menu_cancel(h)
            }
          } else if tag == ev_char() {
            // Any printed char dismisses the dropdown.
            mui_crumb_menu_cancel(h)
          } else if tag == ev_mouse_down() {
            let ch = mui_crumb_menu_row_at_click(h)
            if ch >= 0 {
              let _acc = mui_crumb_menu_accept(h, ch)
              mui_ed_undo_reset(h)
              find_nav = false
              let _r = mui_diag_refresh(h)
              let _o = mui_outline_refresh(h)
            } else {
              mui_crumb_menu_cancel(h)
            }
          }
        }
      } else if palette_open {
        // -------- command palette is open: route keystrokes to it -----------
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          if cp >= 32 && cp < 127 { mui_palette_push_char(h, cp) }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_backspace() {
            mui_palette_backspace(h)
          } else if k == key_up() {
            mui_palette_move(h, -1)
          } else if k == key_down() {
            mui_palette_move(h, 1)
          } else if k == key_escape() {
            mui_palette_cancel(h)
            palette_open = false
          } else if k == key_enter() {
            command_click_id = mui_palette_selected_id(h)
            mui_palette_cancel(h)
            palette_open = false
            typing = false
          }
        } else if tag == ev_mouse_down() {
          let ph = mui_palette_click(h)
          if ph < 0 {
            mui_palette_cancel(h)
            palette_open = false
          } else {
            command_click_id = mui_palette_selected_id(h)
            mui_palette_cancel(h)
            palette_open = false
            typing = false
          }
        }
      } else if quickopen_open {
        // -------- universal Quick-Open open: route keystrokes to the finder ---
        // Mode by first char: (none) fuzzy files / `>` commands / `@` symbols /
        // `:` go-to-line. Up/Down move; Enter accepts (shim opens the file /
        // jumps to the symbol/line, or yields a command id we dispatch); Esc
        // dismisses; Backspace past a prefix drops back to file mode.
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          if cp >= 32 && cp < 127 { mui_qo_push_char(h, cp) }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_backspace() {
            mui_qo_backspace(h)
          } else if k == key_up() {
            mui_qo_move(h, -1)
          } else if k == key_down() {
            mui_qo_move(h, 1)
          } else if k == key_escape() {
            mui_qo_cancel(h)
            quickopen_open = false
          } else if k == key_enter() {
            let mode = mui_qo_mode(h)
            typing = false
            if mode == 1 {
              // Commands mode (`>`): read the selected palette command id, then
              // defer to the shared command dispatcher below.
              command_click_id = mui_qo_command_id(h, -1)
              mui_qo_cancel(h)
              quickopen_open = false
            } else {
              // Files / Symbols / Go-to-line: the shim performs the action
              // (open the file as a tab, or move the cursor) and returns. We
              // mirror the post-open housekeeping the prompt/palette do.
              let r = mui_qo_accept(h, -1)
              quickopen_open = false
              if mode == 0 {
                if r >= 0 {
                  let _b = mui_ed_tab_switch(h, r)
                  mui_ed_undo_reset(h)
                  let _d = mui_diag_refresh(h)
                  let _o = mui_outline_refresh(h)
                  mui_qo_record_active(h)
                }
              } else {
                // Symbols / go-to-line moved the cursor in the active doc.
                find_nav = false
                mui_hover_clear(h)
                hovering = false
              }
            }
          }
        } else if tag == ev_mouse_down() {
          let qh = mui_qo_click(h)
          if qh < 0 {
            mui_qo_cancel(h)
            quickopen_open = false
          } else {
            let mode = mui_qo_mode(h)
            if mode == 1 {
              command_click_id = mui_qo_command_id(h, qh)
              mui_qo_cancel(h)
              quickopen_open = false
              typing = false
            } else {
              let r = mui_qo_accept(h, qh)
              quickopen_open = false
              if mode == 0 {
                if r >= 0 {
                  let _b = mui_ed_tab_switch(h, r)
                  mui_ed_undo_reset(h)
                  let _d = mui_diag_refresh(h)
                  let _o = mui_outline_refresh(h)
                  mui_qo_record_active(h)
                }
              } else {
                find_nav = false
                mui_hover_clear(h)
                hovering = false
              }
            }
          }
        }
      } else if ai_focus && tag != ev_mouse_down() {
        // -------- AI copilot panel focused: route keys to its input ----------
        // (mouse_down is intentionally NOT captured here: a click is positional
        // and must reach the unified mouse router at `ev_mouse_down()` below so
        // the rail / tabs / panel bodies stay clickable while the AI panel has
        // keyboard focus. Previously this arm swallowed clicks, freezing the rail.)
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          let mods = mui_event_mods(h)
          if is_ai_panel_chord(cp, mods) {                  // Ctrl+Shift+A : close/unfocus
            let _o = mui_ai_open(h)
            ai_focus = false
          } else if cp >= 32 && cp < 127 {
            mui_ai_input_push(h, cp)
          }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          let kmods = mui_event_mods(h)
          if k == key_backspace() {
            mui_ai_input_backspace(h)
          } else if k == key_enter() {
            if shift_held(kmods) {
              mui_ai_input_newline(h)                        // Shift+Enter : newline
            } else {
              let _s = mui_ai_send(h)                        // Enter : send
            }
          } else if k == key_up() {
            mui_ai_scroll(h, -1)
          } else if k == key_down() {
            mui_ai_scroll(h, 1)
          } else if k == key_escape() {
            ai_focus = false                                 // Escape : back to editor (panel stays open)
          }
        } else if tag == ev_scroll() {
          let dir = mui_event_scroll_dir(h)
          if dir > 0 { mui_ai_scroll(h, -3) } else { mui_ai_scroll(h, 3) }
        }
      } else if theme_picker_open {
        // -------- color-theme picker open: Up/Down preview, Enter apply -------
        if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_up() {
            mui_theme_picker_move(h, -1)
          } else if k == key_down() {
            mui_theme_picker_move(h, 1)
          } else if k == key_enter() {
            let _t = mui_theme_picker_apply(h)
            theme_picker_open = false
          } else if k == key_escape() {
            mui_theme_picker_cancel(h)
            theme_picker_open = false
          }
        } else if tag == ev_mouse_down() {
          let th = mui_theme_picker_click(h)
          if th == 0 {
            mui_theme_picker_cancel(h)
            theme_picker_open = false
          } else {
            let _t = mui_theme_picker_apply(h)
            theme_picker_open = false
          }
        }
      } else if settings_open {
        // -------- Settings panel open: move rows, adjust/toggle, esc closes ----
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          // '-' decreases, '+'/'=' increases a numeric/theme row; space toggles.
          if cp == 45 {
            mui_settings_adjust(h, -1)
          } else if cp == 43 || cp == 61 {
            mui_settings_adjust(h, 1)
          } else if cp == 32 {
            mui_settings_toggle(h)
          }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_up() {
            mui_settings_move(h, -1)
          } else if k == key_down() {
            mui_settings_move(h, 1)
          } else if k == key_left() {
            mui_settings_adjust(h, -1)
          } else if k == key_right() {
            mui_settings_adjust(h, 1)
          } else if k == key_enter() {
            mui_settings_toggle(h)
          } else if k == key_escape() {
            mui_settings_close(h)
            settings_open = false
          }
        } else if tag == ev_mouse_down() {
          let sc = mui_settings_click(h)
          if sc == 0 {
            mui_settings_close(h)
            settings_open = false
          } else if sc == 2 {
            mui_settings_adjust(h, -1)
          } else if sc == 3 {
            mui_settings_adjust(h, 1)
          } else if sc == 4 {
            mui_settings_toggle(h)
          }
        }
      } else if (run_focus || web_focus) && !(tag == ev_mouse_down() && (mui_rail_panel_at_click(h) >= 0 || mui_rail_utility_at_click(h) >= 0 || mui_topbar_action_at_click(h) > 0)) {
        // -------- Bottom-band panel focused: Run panel OR Web Playground -------
        // A rail-icon click escapes to the unified router (so the rail stays live
        // while this band has focus); the band still handles its own row/button
        // clicks and keyboard. The `tag == ev_mouse_down()` guard short-circuits
        // so the rail hit-test only runs for actual clicks.
        // Both are scroll-output bands with esc-to-unfocus; the Web panel adds
        // Stop / Open-in-browser header buttons. Sharing this ONE top-level arm
        // keeps the editor key ladder at its L37/L38 parse-stack ceiling (no new
        // sibling arm). `web_focus` takes precedence when both are somehow set.
        if web_focus {
          if tag == ev_key() {
            let k = mui_event_key(h)
            if k == key_up() {
              mui_web_scroll(h, -1)
            } else if k == key_down() {
              mui_web_scroll(h, 1)
            } else if k == key_escape() {
              web_focus = false
            }
          } else if tag == ev_scroll() {
            let dir = mui_event_scroll_dir(h)
            if dir > 0 { mui_web_scroll(h, -3) } else { mui_web_scroll(h, 3) }
          } else if tag == ev_mouse_down() {
            let wc = mui_web_click(h)
            if wc == 1 {
              // Stop server.
              mui_web_stop(h)
            } else if wc == 2 {
              // Open the served URL in the default browser.
              let _ob = mui_web_open_browser(h)
            } else {
              // Clicked outside the Web band: release focus so the click flow
              // recovers (the next click reaches the editor / its target).
              web_focus = false
            }
          }
        } else {
          // -------- Run panel: scroll output, click jumps, esc unfocus --------
          if tag == ev_key() {
            let k = mui_event_key(h)
            if k == key_up() {
              mui_run_scroll(h, -1)
            } else if k == key_down() {
              mui_run_scroll(h, 1)
            } else if k == key_escape() {
              run_focus = false
            }
          } else if tag == ev_scroll() {
            let dir = mui_event_scroll_dir(h)
            if dir > 0 { mui_run_scroll(h, -3) } else { mui_run_scroll(h, 3) }
          } else if tag == ev_mouse_down() {
            let rrow = mui_run_row_at_click(h)
            if rrow >= 0 {
              let ok = mui_run_click_row(h, rrow)
              if ok == 1 {
                let newtab = mui_run_click_tab(h)
                if newtab >= 0 {
                  let _b = mui_ed_tab_switch(h, newtab)
                  mui_ed_undo_reset(h)
                  let tl = mui_run_click_line(h)
                  let tc = mui_run_click_col(h)
                  if tl >= 0 { mui_ed_move_to(h, tl, tc) }
                  let _r = mui_diag_refresh(h)
                  run_focus = false
                }
              }
            } else {
              // Clicked outside the Run output band: release focus so the click
              // flow recovers (the next click reaches the editor / its target).
              run_focus = false
            }
          }
        }
      } else if test_focus {
        // -------- Test panel focused: scroll results, click toolbar/rows -------
        if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_up() {
            mui_test_scroll(h, -1)
          } else if k == key_down() {
            mui_test_scroll(h, 1)
          } else if k == key_escape() {
            test_focus = false
          }
        } else if tag == ev_scroll() {
          let dir = mui_event_scroll_dir(h)
          if dir > 0 { mui_test_scroll(h, -3) } else { mui_test_scroll(h, 3) }
        } else if tag == ev_mouse_down() {
          // A rail click while focused can switch panels; check it first so the
          // beaker/other rail icons, utility icons, and titlebar actions still
          // work on the first click.
          let rail_hit = mui_rail_panel_at_click(h)
          let rail_util = mui_rail_utility_at_click(h)
          let topbar_act = mui_topbar_action_at_click(h)
          let tb_hit = mui_test_toolbar_at_click(h)
          if rail_util == 1 {
            let opened = mui_ai_open(h)
            if opened == 1 { ai_focus = true } else { ai_focus = false }
            test_focus = false
          } else if rail_util == 2 {
            let _s = mui_settings_open(h)
            settings_open = true
            test_focus = false
          } else if topbar_act == 1 {
            let opened = mui_run_toggle(h)
            if opened == 1 { run_focus = true; if mui_run_running(h) == 0 { let _r = mui_run_start(h) } }
            test_focus = false
          } else if topbar_act == 2 {
            mui_palette_open(h)
            palette_open = true
            test_focus = false
          } else if rail_hit == rail_test() {
            // Re-clicking the beaker toggles the panel off.
            let _o = mui_test_toggle(h)
            test_focus = false
          } else if rail_hit >= 0 {
            test_focus = false
            if rail_hit == rail_agents() {
              let opened = mui_ai_open(h)
              if opened == 1 { ai_focus = true }
            } else if rail_hit == rail_run() {
              let opened = mui_run_toggle(h)
              if opened == 1 { run_focus = true; if mui_run_running(h) == 0 { let _r = mui_run_start(h) } }
            } else if rail_hit == rail_debug() {
              let _p = mui_panel_set(h, panel_debug())
            } else {
              let _p = mui_panel_set(h, rail_hit)
              if rail_hit == panel_scm() { let _s = mui_scm_refresh(h) }
              if rail_hit == panel_outline() { let _o = mui_outline_refresh(h) }
            }
          } else if tb_hit == test_tb_run() {
            let _r = mui_test_run(h)
          } else if tb_hit == test_tb_stop() {
            mui_test_stop(h)
          } else {
            let trow = mui_test_row_at_click(h)
            if trow >= 0 {
              let ok = mui_test_open_row(h, trow)
              if ok == 1 {
                let newtab = mui_test_click_tab(h)
                if newtab >= 0 {
                  let _b = mui_ed_tab_switch(h, newtab)
                  mui_ed_undo_reset(h)
                  let tl = mui_test_click_line(h)
                  let tc = mui_test_click_col(h)
                  if tl >= 0 { mui_ed_move_to(h, tl, tc) }
                  let _r = mui_diag_refresh(h)
                  test_focus = false
                }
              }
            } else {
              // Clicked outside the Test results: release focus so the click flow
              // recovers (the next click reaches the editor / its target).
              test_focus = false
            }
          }
        }
      } else if diff_open {
        // -------- inline diff view open: scroll, esc returns to editing --------
        if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_up() {
            mui_diff_scroll(h, -1)
          } else if k == key_down() {
            mui_diff_scroll(h, 1)
          } else if k == key_escape() {
            mui_diff_close(h)
            diff_open = false
          }
        } else if tag == ev_scroll() {
          let dir = mui_event_scroll_dir(h)
          if dir > 0 { mui_diff_scroll(h, -3) } else { mui_diff_scroll(h, 3) }
        }
      } else if replacing {
        // -------- in-file replace bar open: route to find/replace fields ------
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          if cp >= 32 && cp < 127 { mui_replace_push(h, cp) }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_backspace() {
            mui_replace_backspace(h)
          } else if k == key_tab() {
            let _f = mui_replace_toggle_focus(h)
          } else if k == key_escape() {
            mui_replace_cancel(h)
            replacing = false
          } else if k == key_enter() {
            // Enter on the replace field replaces all; otherwise replace-next.
            let rf = mui_replace_focus(h)
            if rf == 1 {
              mui_ed_undo_record(h)
              let _n = mui_replace_all(h)
              mui_tab_set_dirty(h, mui_tab_active(h), 1)
            } else {
              mui_ed_undo_record(h)
              let _r = mui_replace_next(h)
              mui_tab_set_dirty(h, mui_tab_active(h), 1)
            }
          }
        }
      } else if prompt_kind != 0 {
        // -------- a prompt is open: route keystrokes to the prompt buffer ----
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          if cp >= 32 && cp < 127 { mui_prompt_push(h, cp) }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_backspace() {
            mui_prompt_backspace(h)
          } else if k == key_escape() {
            mui_prompt_cancel(h)
            prompt_kind = 0
          } else if k == key_enter() {
            if prompt_kind == prompt_goto() {
              let target1 = mui_prompt_goto_target(h)
              if target1 >= 1 { mui_ed_move_to(h, target1 - 1, 0) }
              mui_prompt_cancel(h)
              prompt_kind = 0
            } else if prompt_kind == prompt_open() {
              mui_path_clear(h)
              let plen = mui_prompt_len(h)
              let mut pi: I32 = 0
              while pi < plen {
                let pc = mui_prompt_char(h, pi)
                if pc >= 0 { mui_path_push(h, pc) }
                pi = pi + 1
              }
              let newidx = mui_tab_open_path(h)
              let _b = mui_ed_tab_switch(h, newidx)
              mui_ed_undo_reset(h)
              find_nav = false
              let _r = mui_diag_refresh(h)
              mui_qo_record_active(h)
              mui_prompt_cancel(h)
              prompt_kind = 0
            } else if prompt_kind == prompt_open_folder() {
              // Open Folder typed-path fallback: stage the typed path into the
              // shared byte buffer, then re-root the workspace (tree/index/search/
              // git/agents) + record the folder in recents. The shim toasts the
              // result + validates the path.
              mui_path_clear(h)
              let flen = mui_prompt_len(h)
              let mut fi: I32 = 0
              while fi < flen {
                let fc = mui_prompt_char(h, fi)
                if fc >= 0 { mui_path_push(h, fc) }
                fi = fi + 1
              }
              let _wo = mui_ws_open(h)
              find_nav = false
              mui_prompt_cancel(h)
              prompt_kind = 0
            } else if prompt_kind == prompt_new_project() {
              // New Project: stage the typed NAME into the shared byte buffer,
              // then run `mty new <name>` + open the result as the workspace.
              // The shim validates the name + toasts (success / invalid / mty
              // missing); we just clear the prompt afterward.
              mui_path_clear(h)
              let nlen = mui_prompt_len(h)
              let mut ni: I32 = 0
              while ni < nlen {
                let nc = mui_prompt_char(h, ni)
                if nc >= 0 { mui_path_push(h, nc) }
                ni = ni + 1
              }
              let _np = mui_newproj_create(h)
              find_nav = false
              mui_prompt_cancel(h)
              prompt_kind = 0
            } else if prompt_kind == prompt_new_folder() {
              // New Folder: stage the typed name into the shared byte buffer, then
              // create the directory under the workspace root + refresh the tree.
              mui_path_clear(h)
              let dlen = mui_prompt_len(h)
              let mut di: I32 = 0
              while di < dlen {
                let dc = mui_prompt_char(h, di)
                if dc >= 0 { mui_path_push(h, dc) }
                di = di + 1
              }
              let _nf = mui_newfolder_create(h)
              find_nav = false
              mui_prompt_cancel(h)
              prompt_kind = 0
            } else if prompt_kind == prompt_save_as() {
              // Save As: stage the typed name, write the untitled buffer there,
              // bind the tab to the path, then refresh SCM/diagnostics/tree.
              mui_path_clear(h)
              let slen = mui_prompt_len(h)
              let mut si: I32 = 0
              while si < slen {
                let sc = mui_prompt_char(h, si)
                if sc >= 0 { mui_path_push(h, sc) }
                si = si + 1
              }
              let src = mui_save_as(h)
              if src == 0 {
                mui_tab_set_dirty(h, mui_tab_active(h), 0)
                let _r = mui_diag_refresh(h)
                let _g = mui_scm_refresh(h)
                let _o = mui_outline_refresh(h)
                let _pr = mui_problems_refresh(h)
              }
              find_nav = false
              mui_prompt_cancel(h)
              prompt_kind = 0
            } else if prompt_kind == prompt_ai() {
              // Inline ask: copy the typed instruction into the AI input, then
              // send it (with the active file + selection as context). The answer
              // streams into the right-docked AI panel.
              let qlen = mui_prompt_len(h)
              let mut qi: I32 = 0
              while qi < qlen {
                let qc = mui_prompt_char(h, qi)
                if qc >= 0 { mui_ai_input_push(h, qc) }
                qi = qi + 1
              }
              let _s = mui_ai_send_inline(h)
              ai_focus = true
              mui_prompt_cancel(h)
              prompt_kind = 0
            } else {
              // find: run, jump to the first match if any (keep matches for nav).
              let cnt = mui_ed_find_run(h)
              if cnt > 0 {
                find_nav = true
                find_idx = 0
                jump_to_match(h, find_idx)
              } else {
                find_nav = false
              }
              mui_prompt_cancel(h)
              prompt_kind = 0
            }
          }
        }
      } else if term_focus && tag != ev_mouse_down() {
        // -------- terminal has focus: route keystrokes to the shell ---------
        // mouse_down falls through to the unified router so the rail/tabs stay
        // clickable while the terminal has keyboard focus.
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          let mods = mui_event_mods(h)
          if ctrl_held(mods) && cp == 96 {                  // Ctrl+` : unfocus
            term_focus = false
          } else {
            mui_term_send_codepoint(h, cp, mods)
          }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          let kmods = mui_event_mods(h)
          mui_term_key(h, k, kmods)
        }
      } else if completing {
        // -------- autocomplete dropdown is open ------------------------------
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          let is_ident = (cp >= 97 && cp <= 122) || (cp >= 65 && cp <= 90) || (cp >= 48 && cp <= 57) || cp == 95
          if is_ident {
            mui_ed_insert_char(h, cp)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
            let _c = mui_ed_complete_request(h)
            mui_snippet_inject_completions(h)
            let cnt = mui_complete_count(h)
            if cnt == 0 { mui_complete_cancel(h); completing = false }
          } else {
            mui_complete_cancel(h)
            completing = false
            if cp >= 32 && cp < 127 {
              mui_ed_insert_char(h, cp)
              mui_tab_set_dirty(h, mui_tab_active(h), 1)
            }
          }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_up() {
            mui_complete_move(h, -1)
          } else if k == key_down() {
            mui_complete_move(h, 1)
          } else if k == key_enter() || k == key_tab() {
            // (3) Accept the selected candidate. A snippet entry EXPANDS its body
            // (and begins the tab-stop session); a plain entry inserts its text.
            mui_ed_undo_record(h)
            if mui_snippet_complete_is(h) == 1 {
              let _e = mui_snippet_complete_expand(h)
            } else {
              let _a = mui_ed_complete_accept(h)
            }
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
            mui_complete_cancel(h)
            completing = false
            typing = false
          } else if k == key_escape() {
            mui_complete_cancel(h)
            completing = false
          } else if k == key_backspace() {
            mui_ed_backspace(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
            let _c = mui_ed_complete_request(h)
            mui_snippet_inject_completions(h)
            let cnt = mui_complete_count(h)
            if cnt == 0 { mui_complete_cancel(h); completing = false }
          } else {
            mui_complete_cancel(h)
            completing = false
          }
        } else if tag == ev_mouse_down() {
          let c_line = mui_ed_cursor_line(h)
          let c_col = mui_ed_cursor_col(h)
          let total_c = mui_ed_line_count(h)
          let ch = mui_complete_click_at(h, c_line - first, c_col, total_c)
          if ch >= 0 {
            mui_ed_undo_record(h)
            if mui_snippet_complete_is(h) == 1 {
              let _e = mui_snippet_complete_expand(h)
            } else {
              let _a = mui_ed_complete_accept(h)
            }
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
            mui_complete_cancel(h)
            completing = false
            typing = false
          } else {
            mui_complete_cancel(h)
            completing = false
          }
        }
      } else if renaming {
        // -------- rename inline input is open: route to the new-name buffer ----
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          // Accept identifier chars only (letters / digits / underscore).
          let is_ident = (cp >= 97 && cp <= 122) || (cp >= 65 && cp <= 90) || (cp >= 48 && cp <= 57) || cp == 95
          if is_ident { mui_rename_push_char(h, cp) }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_backspace() {
            mui_rename_backspace(h)
          } else if k == key_escape() {
            mui_rename_cancel(h)
            renaming = false
          } else if k == key_enter() {
            mui_ed_undo_record(h)
            let nfiles = mui_rename_commit(h, rename_line, rename_col)
            renaming = false
            if nfiles >= 1 {
              mui_tab_set_dirty(h, mui_tab_active(h), 0)
              let _r = mui_diag_refresh(h)
            }
          }
        }
      } else if code_action_open {
        // -------- code-action menu is open: route navigation + apply -----------
        if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_up() {
            mui_codeaction_move(h, -1)
          } else if k == key_down() {
            mui_codeaction_move(h, 1)
          } else if k == key_enter() {
            mui_ed_undo_record(h)
            let _a = mui_codeaction_apply(h)
            code_action_open = false
            let _n = mui_ed_load(h)
            mui_ed_undo_reset(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 0)
            let _r = mui_diag_refresh(h)
          } else if k == key_escape() {
            mui_codeaction_cancel(h)
            code_action_open = false
          }
        } else if tag == ev_char() {
          // Any printed char dismisses the menu (then re-handled next frame).
          mui_codeaction_cancel(h)
          code_action_open = false
        } else if tag == ev_mouse_down() {
          let total_ca = mui_ed_line_count(h)
          let ch = mui_codeaction_click(h, ca_line - first, ca_col, total_ca)
          if ch >= 0 {
            mui_ed_undo_record(h)
            let _a = mui_codeaction_apply(h)
            code_action_open = false
            let _n = mui_ed_load(h)
            mui_ed_undo_reset(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 0)
            let _r = mui_diag_refresh(h)
          } else {
            mui_codeaction_cancel(h)
            code_action_open = false
          }
        }
      } else if mui_panel_active(h) == panel_search() && tag != ev_mouse_down() {
        // -------- Search panel has focus: type into the query/replace field ---
        // mouse_down falls through to the unified router (rail clicks switch
        // panels; a result-row click opens the match) — see `ev_mouse_down()`.
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          if cp >= 32 && cp < 127 { mui_search_push_char(h, cp) }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_backspace() {
            mui_search_backspace(h)
          } else if k == key_tab() {
            let _f = mui_search_toggle_focus(h)
          } else if k == key_enter() {
            // Enter runs the search; if the replace field has focus, replace all.
            let rf = mui_search_replace_focus(h)
            if rf == 1 {
              let _r = mui_search_replace_all(h)
            } else {
              let _c = mui_search_run(h)
            }
          } else if k == key_escape() {
            let _p = mui_panel_set(h, panel_explorer())
          }
        }
      } else if mui_panel_active(h) == panel_scm() && tag != ev_mouse_down() {
        // -------- Source Control panel has focus: commit-message input --------
        // mouse_down falls through to the unified router (rail clicks switch
        // panels; a row click stages/opens the file) — see `ev_mouse_down()`.
        if tag == ev_char() {
          let cp = mui_event_codepoint(h)
          if cp >= 32 && cp < 127 { mui_scm_msg_push(h, cp) }
        } else if tag == ev_key() {
          let k = mui_event_key(h)
          if k == key_backspace() {
            mui_scm_msg_backspace(h)
          } else if k == key_enter() {
            let ok = mui_scm_commit(h)
            if ok == 1 { log("mighty-ide: committed") }
          } else if k == key_escape() {
            let _p = mui_panel_set(h, panel_explorer())
          }
        }
      } else if tag == ev_char() {
        let cp = mui_event_codepoint(h)
        let mods = mui_event_mods(h)
        let routed_cmd = mui_chord_command_id(h, cp, mods)
        if routed_cmd >= 0 {
          // Any remappable default or override goes through the shared command
          // dispatcher below. That keeps shortcut remaps, palette Enter, and
          // Quick-Open command mode behavior identical.
          command_click_id = routed_cmd
          typing = false
        } else if routed_cmd == -2 {
          // A command was remapped away from this old default chord; consume it
          // so the legacy hard-coded branch does not still fire.
          typing = false
        } else if is_palette_chord(cp, mods) {              // Ctrl+Shift+P : palette
          mui_palette_open(h)
          palette_open = true
          typing = false
        } else if is_quickopen_chord(cp, mods) {            // Ctrl+P : universal Quick-Open
          mui_quickopen_open(h)
          quickopen_open = true
          typing = false
        } else if is_run_chord(cp, mods) {                  // Ctrl+Shift+R : run the active file
          let _r = mui_run_start(h)
          run_focus = true
          typing = false
        } else if is_run_tests_chord(cp, mods) {            // Ctrl+Shift+T : run the package's tests
          let _t = mui_test_run(h)
          test_focus = true
          run_focus = false
          typing = false
        } else if ctrl_held(mods) && cp == 44 {             // Ctrl+, : Settings
          let _s = mui_settings_open(h)
          settings_open = true
          typing = false
        } else if is_ai_panel_chord(cp, mods) {             // Ctrl+Shift+A : AI copilot panel
          let opened = mui_ai_open(h)
          if opened == 1 { ai_focus = true } else { ai_focus = false }
          typing = false
        } else if is_router_chord(cp, mods) {               // Alt chords (Alt+\ ghost, Alt+Z zen, …) + split-pane Ctrl chords (Ctrl+\, Ctrl+1/2) via the shim router
          let rid = mui_chord_command_id(h, cp, mods)
          if rid >= 0 {
            command_click_id = rid
          } else {
            let _c = mui_chord(h, cp, mods)
          }
          typing = false
        } else if is_inline_ask_chord(cp, mods) {           // Ctrl+I : inline ask about selection/file
          // Reuse the prompt UI to collect an instruction; routed on Enter to
          // the AI panel (see the prompt_kind == prompt_ai() branch).
          mui_prompt_open(h, prompt_ai())
          prompt_kind = prompt_ai()
          find_nav = false
          typing = false
        } else if is_search_panel_chord(cp, mods) {         // Ctrl+Shift+F : search panel
          let _p = mui_panel_set(h, panel_search())
        } else if is_scm_panel_chord(cp, mods) {            // Ctrl+Shift+G : source control
          let _p = mui_panel_set(h, panel_scm())
          let _s = mui_scm_refresh(h)
        } else if ctrl_held(mods) && shift_held(mods) && cp == 32 {  // Ctrl+Shift+Space : signature help
          let ok = do_signature_help(h)
          if ok == 1 {
            sig_open = true
            sig_line = mui_ed_cursor_line(h)
            sig_col = mui_ed_cursor_col(h)
          } else {
            sig_open = false
          }
        } else if ctrl_held(mods) && cp == 46 {              // Ctrl+. : code actions / quick-fix
          let cnt = mui_codeaction_request(h, mui_ed_cursor_line(h), mui_ed_cursor_col(h))
          if cnt > 0 {
            code_action_open = true
            ca_line = mui_ed_cursor_line(h)
            ca_col = mui_ed_cursor_col(h)
          } else {
            mui_codeaction_cancel(h)
          }
        } else if ctrl_held(mods) && cp == 32 {             // Ctrl+Space : autocomplete
          let _c = mui_ed_complete_request(h)
          mui_snippet_inject_completions(h)                 // snippet prefixes appear with a "snippet" badge
          let cnt = mui_complete_count(h)
          if cnt > 0 { completing = true } else { mui_complete_cancel(h) }
        } else if ctrl_held(mods) && (cp == 107 || cp == 75) {  // Ctrl+K : hover
          let ok = do_hover(h)
          if ok == 1 { hovering = true; hover_line = mui_ed_cursor_line(h); hover_col = mui_ed_cursor_col(h) } else { hovering = false }
        } else if ctrl_held(mods) && cp == 45 {             // Ctrl+Minus : jump back
          if have_prev {
            mui_ed_move_to(h, prev_line, prev_col)
            have_prev = false
            mui_hover_clear(h)
            hovering = false
          }
        } else if ctrl_held(mods) && cp == 96 {             // Ctrl+` : toggle terminal
          if mui_term_is_open(h) == 1 {
            term_focus = true
          } else {
            let ok = mui_term_open(h)
            if ok == 1 { term_focus = true; mui_log_terminal(h) }
          }
        } else if ctrl_held(mods) && (cp == 115 || cp == 83) {  // Ctrl+S : save
          // Untitled buffer (no path): open a Save-As prompt instead of failing.
          if mui_active_has_path(h) == 0 {
            let sr = mui_save_as_dialog(h)
            if sr == 0 {
              mui_tab_set_dirty(h, mui_tab_active(h), 0)
              let _r = mui_diag_refresh(h)
              let _g = mui_scm_refresh(h)
              let _o = mui_outline_refresh(h)
              let _pr = mui_problems_refresh(h)
            } else {
              mui_prompt_open(h, prompt_save_as())
              prompt_kind = prompt_save_as()
              find_nav = false
            }
          } else {
            let rc = mui_ed_save(h)
            if rc == 0 { log("mighty-ide: saved") } else { log("mighty-ide: save FAILED") }
            if rc == 0 {
              mui_tab_set_dirty(h, mui_tab_active(h), 0)
              let _r = mui_diag_refresh(h)
              let _g = mui_scm_refresh(h)
              let _o = mui_outline_refresh(h)
              let _pr = mui_problems_refresh(h)
            }
          }
          typing = false
        } else if is_undo_chord(cp, mods) {                  // Ctrl+Z : undo
          mui_complete_cancel(h)
          completing = false
          find_nav = false
          typing = false
          let _u = mui_ed_undo(h)
        } else if is_redo_chord(cp, mods) {                  // Ctrl+Y / Ctrl+Shift+Z : redo
          mui_complete_cancel(h)
          completing = false
          find_nav = false
          typing = false
          let _u = mui_ed_redo(h)
        } else if is_format_chord(cp, mods) {                // Ctrl+Shift+I : format
          do_format(h)
          typing = false
        } else if ctrl_held(mods) && (cp == 103 || cp == 71) {   // Ctrl+G : go to line
          mui_prompt_open(h, prompt_goto())
          prompt_kind = prompt_goto()
          find_nav = false
        } else if ctrl_held(mods) && (cp == 102 || cp == 70) {   // Ctrl+F : find
          mui_prompt_open(h, prompt_find())
          prompt_kind = prompt_find()
        } else if ctrl_held(mods) && (cp == 111 || cp == 79) {   // Ctrl+O : open file
          let oi = mui_open_file_dialog(h)
          if oi >= 0 {
            let _b = mui_ed_tab_switch(h, oi)
            mui_ed_undo_reset(h)
            find_nav = false
            let _r = mui_diag_refresh(h)
            let _o = mui_outline_refresh(h)
            mui_qo_record_active(h)
          } else {
            mui_prompt_open(h, prompt_open())
            prompt_kind = prompt_open()
            find_nav = false
          }
        } else if is_d_chord(cp, mods) {                         // Ctrl+D add-caret / Ctrl+Shift+D duplicate
          find_nav = false
          typing = false
          if shift_held(mods) {                                  // Ctrl+Shift+D : duplicate line/sel
            mui_ed_undo_record(h)
            mui_ed_duplicate(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
          } else {                                               // Ctrl+D : add caret at next occurrence
            let _d = mui_ed_add_caret_next(h)
          }
        } else if is_replace_chord(cp, mods) {                   // Ctrl+H : in-file replace
          mui_replace_open(h)
          replacing = true
          find_nav = false
          typing = false
        } else if ctrl_held(mods) && cp == 47 {                  // Ctrl+/ : toggle comment
          find_nav = false
          mui_ed_undo_record(h)
          typing = false
          mui_ed_toggle_comment(h)
          mui_tab_set_dirty(h, mui_tab_active(h), 1)
        } else if ctrl_held(mods) && (cp == 98 || cp == 66) {    // Ctrl+B : toggle sidebar
          let _s = mui_sidebar_toggle(h)
        } else if ctrl_held(mods) && (cp == 119 || cp == 87) {   // Ctrl+W : close active tab
          let cur_active = mui_tab_active(h)
          let a = mui_tab_close(h, cur_active)
          let _b = mui_ed_tab_switch(h, a)
          mui_ed_undo_reset(h)
          find_nav = false
          let _r = mui_diag_refresh(h)
        } else if find_nav && (cp == 110 || cp == 78) {     // 'n' / 'N' : next match
          let cnt = mui_find_count(h)
          if cnt > 0 {
            find_idx = find_idx + 1
            if find_idx >= cnt { find_idx = 0 }
            jump_to_match(h, find_idx)
          }
        } else if cp >= 32 && cp < 127 {                    // printable ASCII : insert
          find_nav = false
          // Typing on the Welcome landing dismisses it so the editor (and what
          // the user is typing) becomes visible — otherwise the first keystrokes
          // vanish into the hidden buffer behind the landing.
          if mui_welcome_active(h) == 1 { mui_welcome_dismiss(h) }
          // Record an undo checkpoint at the start of a typing run only.
          if !typing { mui_ed_undo_record(h); typing = true }
          // Snippet mode: typing over a selected tab-stop placeholder replaces it
          // (delete the selection first so the typed char takes its place).
          if mui_snippet_active(h) == 1 { let _r = mui_snippet_replace_stop(h) }
          // Bracket/quote auto-close + skip-over at EVERY caret (falls back to a
          // plain insert per-caret where the smart path declines).
          mui_ed_insert_smart_multi(h, cp)
          mui_tab_set_dirty(h, mui_tab_active(h), 1)
          // Inline AI: the current ghost (if any) is now stale — dismiss + re-arm
          // the debounced request so a fresh suggestion can follow the pause.
          mui_ghost_dismiss(h)
          mui_ghost_arm(h)
          // As-you-type autocomplete: after an identifier char, request completion
          // and pop the dropdown when there are matches (like a real IDE). Setting
          // `completing` hands subsequent keystrokes to the completion arm above,
          // which inserts + re-filters; a non-match / Esc closes it.
          let is_ident_cp = (cp >= 97 && cp <= 122) || (cp >= 65 && cp <= 90) || (cp >= 48 && cp <= 57) || cp == 95
          if is_ident_cp {
            let _c = mui_ed_complete_request(h)
            mui_snippet_inject_completions(h)
            let cnt = mui_complete_count(h)
            if cnt > 0 { completing = true }
          }
          // After typing '(' auto-trigger signature help; ')' dismisses it.
          if cp == 40 {
            let ok = do_signature_help(h)
            if ok == 1 {
              sig_open = true
              sig_line = mui_ed_cursor_line(h)
              sig_col = mui_ed_cursor_col(h)
            }
          } else if cp == 41 {
            mui_sig_clear(h)
            sig_open = false
          }
        }
      } else if tag == ev_key() {
        let k = mui_event_key(h)
        if mui_peek_active(h) == 1 {
          // The inline peek card captures keys while it is up: Esc closes it,
          // Enter navigates to the actual definition, Up/Down scroll the preview.
          if k == key_escape() {
            mui_peek_close(h)
          } else if k == key_enter() {
            let r = mui_peek_goto(h)
            if r >= 0 {
              let _b = mui_ed_tab_switch(h, mui_tab_active(h))
              let _d = mui_diag_refresh(h)
              let _o = mui_outline_refresh(h)
            }
            find_nav = false
          } else if k == key_up() {
            mui_peek_scroll(h, -1)
          } else if k == key_down() {
            mui_peek_scroll(h, 1)
          } else {
            mui_peek_close(h)                                 // any other key dismisses
          }
        } else if k == key_f12() {
          let kmods = mui_event_mods(h)
          if alt_held(kmods) {                               // Alt+F12 : peek definition
            let _p = peek_definition(h)
          } else {                                           // F12 : go to definition
            prev_line = mui_ed_cursor_line(h)
            prev_col = mui_ed_cursor_col(h)
            go_to_definition(h)
            have_prev = true
            find_nav = false
          }
        } else if k == key_f2() {                            // F2 : rename symbol
          let cl = mui_ed_cursor_line(h)
          let cc = mui_ed_cursor_col(h)
          let ok = mui_rename_prepare(h, cl, cc)
          if ok == 1 {
            renaming = true
            rename_line = cl
            rename_col = cc
            mui_sig_clear(h)
            sig_open = false
          }
        } else if k == key_f5() {                            // F5 / Shift+F5 : start-continue / stop
          let kmods = mui_event_mods(h)
          if shift_held(kmods) {
            mui_dbg_stop(h)
          } else {
            let _st = mui_dbg_start(h)
          }
        } else if k == key_f10() {                           // F10 : step over
          mui_dbg_step_over(h)
        } else if k == key_f11() {                           // F11 / Shift+F11 : step into / out
          let kmods = mui_event_mods(h)
          if shift_held(kmods) { mui_dbg_step_out(h) } else { mui_dbg_step_into(h) }
        } else if k == key_escape() {
          find_nav = false
          mui_hover_clear(h)
          hovering = false
          mui_sig_clear(h)
          sig_open = false
          mui_ghost_dismiss(h)                                 // Esc dismisses the inline ghost
          mui_snippet_cancel(h)                                // Esc ends the snippet tab-stop session
          mui_ed_collapse_carets(h)                            // Esc collapses to the primary caret
        } else if k == key_tab() {
          let kmods = mui_event_mods(h)
          if ctrl_held(kmods) {
            // Ctrl+Tab next / Ctrl+Shift+Tab prev. Tab switch is a plain index
            // change now (each tab owns its model) — no byte-swap loop.
            let mut a = mui_tab_next(h)
            if shift_held(kmods) { a = mui_tab_prev(h) }
            let _b = mui_ed_tab_switch(h, a)
            mui_ed_undo_reset(h)
            find_nav = false
            let _r = mui_diag_refresh(h)
            let _o = mui_outline_refresh(h)
          } else if mui_snippet_active(h) == 1 {
            // (1) A tab-stop session is in progress: Shift+Tab -> previous stop,
            // Tab -> next stop. The final Tab jumps to $0 and ends the session.
            typing = false
            if shift_held(kmods) {
              let _p = mui_snippet_prev_stop(h)
            } else {
              let _n = mui_snippet_next_stop(h)
            }
          } else if mui_ghost_has(h) == 1 {
            // (2) Tab accepts the inline AI ghost suggestion (insert at cursor).
            mui_ed_undo_record(h)
            typing = false
            let _a = mui_ghost_accept(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
          } else if mui_snippet_try_expand(h) == 1 {
            // (4) The word before the cursor is a snippet prefix -> expand it,
            // begin the tab-stop session, select the first stop. (Step (3),
            // completion dropdown, is handled in the `completing` branch above.)
            typing = false
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
            mui_ghost_dismiss(h)
          } else {
            // (5) Nothing took the Tab -> insert an indent.
            if !typing { mui_ed_undo_record(h); typing = true }
            mui_ed_insert_char_multi(h, 9)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
          }
        } else if k == key_left() {
          let kmods = mui_event_mods(h)
          let ext = ext_flag(shift_held(kmods))
          mui_ghost_dismiss(h)                                // cursor move: ghost stale
          if ctrl_held(kmods) {
            mui_ed_move_word_multi(h, 0, ext)                 // Ctrl+Left : word left
          } else {
            mui_ed_move_ext_multi(h, dir_left(), ext)
          }
          typing = false
        } else if k == key_right() {
          let kmods = mui_event_mods(h)
          let ext = ext_flag(shift_held(kmods))
          if ctrl_held(kmods) && mui_ghost_has(h) == 1 {
            // Ctrl+Right with a ghost shown: partial-accept ONE word; the rest of
            // the suggestion stays as the ghost.
            mui_ed_undo_record(h)
            let _a = mui_ghost_accept_word(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
          } else if ctrl_held(kmods) {
            mui_ghost_dismiss(h)
            mui_ed_move_word_multi(h, 1, ext)                 // Ctrl+Right : word right
          } else {
            mui_ghost_dismiss(h)
            mui_ed_move_ext_multi(h, dir_right(), ext)
          }
          typing = false
        } else if k == key_up() {
          let kmods = mui_event_mods(h)
          mui_ghost_dismiss(h)                                 // cursor move: ghost stale
          if ctrl_held(kmods) && alt_held(kmods) {             // Ctrl+Alt+Up : add caret above
            find_nav = false
            let _a = mui_ed_add_caret_above(h)
          } else if alt_held(kmods) {                          // Alt+Up : move line up
            find_nav = false
            mui_ed_undo_record(h)
            mui_ed_move_lines_up(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
          } else {
            mui_ed_move_ext_multi(h, dir_up(), ext_flag(shift_held(kmods)))
          }
          typing = false
        } else if k == key_down() {
          let kmods = mui_event_mods(h)
          mui_ghost_dismiss(h)                                 // cursor move: ghost stale
          if ctrl_held(kmods) && alt_held(kmods) {             // Ctrl+Alt+Down : add caret below
            find_nav = false
            let _a = mui_ed_add_caret_below(h)
          } else if alt_held(kmods) {                          // Alt+Down : move line down
            find_nav = false
            mui_ed_undo_record(h)
            mui_ed_move_lines_down(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
          } else {
            mui_ed_move_ext_multi(h, dir_down(), ext_flag(shift_held(kmods)))
          }
          typing = false
        } else if k == key_home() {
          let kmods = mui_event_mods(h)
          mui_ghost_dismiss(h)
          mui_ed_home_smart_multi(h, ext_flag(shift_held(kmods)))
          typing = false
        } else if k == key_end() {
          let kmods = mui_event_mods(h)
          mui_ghost_dismiss(h)
          mui_ed_move_ext_multi(h, dir_end(), ext_flag(shift_held(kmods)))
          typing = false
        } else if k == key_backspace() {
          find_nav = false
          mui_ed_undo_record(h)
          typing = false
          // Backspace at EVERY caret (smart pair-delete where applicable).
          mui_ed_backspace_multi(h)
          mui_tab_set_dirty(h, mui_tab_active(h), 1)
          mui_ghost_dismiss(h)                                 // edit: ghost stale, re-arm
          mui_ghost_arm(h)
        } else if k == key_delete() {
          find_nav = false
          mui_ed_undo_record(h)
          typing = false
          mui_ed_delete_multi(h)
          mui_tab_set_dirty(h, mui_tab_active(h), 1)
          mui_ghost_dismiss(h)
          mui_ghost_arm(h)
        } else if k == key_enter() {
          if find_nav {
            let cnt = mui_find_count(h)
            if cnt > 0 {
              find_idx = find_idx + 1
              if find_idx >= cnt { find_idx = 0 }
              jump_to_match(h, find_idx)
            }
          } else {
            mui_ed_undo_record(h)
            typing = false
            mui_ed_newline_indent_multi(h)
            mui_tab_set_dirty(h, mui_tab_active(h), 1)
            mui_ghost_dismiss(h)                               // edit: ghost stale, re-arm
            mui_ghost_arm(h)
          }
        }
      } else if tag == ev_scroll() {
        let dir = mui_event_scroll_dir(h)
        if dir > 0 {
          if first >= 3 { first = first - 3 } else { first = 0 }
        } else if dir < 0 {
          first = first + 3
        }
      } else if tag == ev_mouse_down() {
        // Route the click: an open breadcrumb dropdown first (it overlays the
        // body), then rail icon, breadcrumb segments, the status problems chip,
        // tab bar, the active sidebar/bottom panel, or the text area.
        let rail_hit = mui_rail_panel_at_click(h)
        let rail_util = mui_rail_utility_at_click(h)
        let tab_hit = mui_tab_index_at_click(h)
        let tab_close_hit = mui_tab_close_index_at_click(h)
        let cur_panel = mui_panel_active(h)
        let crumb_on = mui_crumb_menu_active(h)
        let crumb_hit = mui_crumb_menu_row_at_click(h)
        let bc_seg = mui_breadcrumb_click_row(h)
        // Breadcrumb "Preview" pill (only present when the active file is .md):
        // opens the live split-pane Markdown preview. Returns 1 when it handled
        // the click. Computed up-front so the dispatch ladder stays flat (L27).
        let md_btn = mui_md_button_at_click(h)
        let chip_hit = mui_status_problems_chip_at_click(h)
        let prob_on = mui_problems_is_open(h)
        let prob_hit = mui_problems_row_at_click(h)
        // Git click targets (computed up-front so the dispatch ladder stays flat):
        // the status-bar branch segment opens the switcher; a click on an inline-
        // diff hunk header stages/unstages that hunk.
        let branch_seg = mui_status_branch_at_click(h)
        let diff_on = mui_diff_active(h)
        let mut diff_hunk: I32 = 0 - 1
        if diff_on == 1 { diff_hunk = mui_diff_hunk_at_click(h) }
        // When the Welcome screen owns the body, a click on it dispatches a
        // quick action (or opens a recent file). Handled first; if the click
        // missed the cards we fall through to the normal routing (rail/tabs).
        // (Several actions set Mighty-side mode flags, so the dispatch is inline
        // here — a helper can't write the caller's `palette_open`/etc. locals, L27.)
        let welcome_owns = mui_welcome_active(h)
        let welcome_act = welcome_click_action(h, welcome_owns)
        // Top-right title-bar action icons (run ▶ / more-actions ⋯). 0 = none.
        let topbar_act = mui_topbar_action_at_click(h)
        let ai_click = mui_ai_click(h)
        // Explorer header buttons (new file / new folder / collapse). 0 = none.
        // Only meaningful when the Explorer panel is the active sidebar panel.
        let mut explorer_hit: I32 = 0
        if cur_panel == panel_explorer() { explorer_hit = mui_explorer_header_at_click(h) }
        if diff_on == 1 && diff_hunk >= 0 {
          // Inline-diff hunk header clicked: stage (working-tree) / unstage
          // (staged) that hunk. The shim picks the verb by the diff's side and
          // refreshes SCM + the diff afterward.
          let _hs = mui_diff_toggle_hunk(h, diff_hunk)
        } else if branch_seg == 1 {
          // Status-bar branch segment: open the branch switcher overlay.
          let n = mui_git_branches(h)
          if n >= 0 { branch_open = true }
        } else if welcome_act >= 0 {
          if welcome_act == welcome_open_file() {
            let oi = mui_open_file_dialog(h)
            if oi >= 0 {
              let _b = mui_ed_tab_switch(h, oi)
              mui_ed_undo_reset(h)
              find_nav = false
              let _r = mui_diag_refresh(h)
              let _o = mui_outline_refresh(h)
              mui_qo_record_active(h)
            } else {
              mui_prompt_open(h, prompt_open())
              prompt_kind = prompt_open()
              find_nav = false
            }
          } else if welcome_act == welcome_quick_open() {
            mui_quickopen_open(h)
            quickopen_open = true
          } else if welcome_act == welcome_palette() {
            mui_palette_open(h)
            palette_open = true
          } else if welcome_act == welcome_new_file() {
            // New File from Welcome should create an actual untitled tab, not
            // merely reveal the startup scratch file underneath.
            let ni = mui_tab_new_untitled(h)
            let _b = mui_ed_tab_switch(h, ni)
            mui_ed_undo_reset(h)
            find_nav = false
          } else if welcome_act == welcome_toggle_theme() {
            mui_theme_picker_open(h)
            theme_picker_open = true
          } else if welcome_act == welcome_open_folder() {
            // Open Folder quick action: native picker, prompt fallback.
            let wd = mui_ws_open_dialog(h)
            if wd == 0 {
              mui_prompt_open(h, prompt_open_folder())
              prompt_kind = prompt_open_folder()
              find_nav = false
            }
          } else if welcome_act >= welcome_recent_folder_base() {
            // A recent FOLDER row: re-root the workspace (id - FOLDER_BASE).
            let fidx = welcome_act - welcome_recent_folder_base()
            let _wf = mui_welcome_open_folder(h, fidx)
            find_nav = false
            let _r = mui_diag_refresh(h)
          } else {
            // A recent FILE row: open it as a tab (id - ACTION_RECENT_BASE).
            let ridx = welcome_act - welcome_recent_base()
            let newtab = mui_welcome_open_recent(h, ridx)
            if newtab >= 0 {
              let _b = mui_ed_tab_switch(h, newtab)
              mui_ed_undo_reset(h)
              find_nav = false
              let _r = mui_diag_refresh(h)
              let _o = mui_outline_refresh(h)
            }
          }
        } else if crumb_on == 1 {
          // A dropdown is open: a row click accepts it, anything else dismisses.
          if crumb_hit >= 0 {
            let _acc = mui_crumb_menu_accept(h, crumb_hit)
            mui_ed_undo_reset(h)
            find_nav = false
            let _r = mui_diag_refresh(h)
          } else {
            mui_crumb_menu_cancel(h)
          }
        } else if md_btn == 1 {
          // Breadcrumb "Preview" pill: the shim already opened the split preview.
          find_nav = false
        } else if bc_seg >= 0 {
          // Clicked a breadcrumb segment: open its dropdown (file / symbol).
          let _seg = mui_breadcrumb_click(h)
        } else if chip_hit == 1 {
          // Status-bar problems chip: open + refresh the Problems panel.
          let _po = mui_problems_open(h)
        } else if prob_on == 1 && prob_hit >= 0 {
          // Problems panel row: open the file + jump to the diagnostic.
          let newidx = mui_problems_open_row(h, prob_hit)
          if newidx >= 0 {
            let _b = mui_ed_tab_switch(h, newidx)
            mui_ed_undo_reset(h)
            find_nav = false
            let _r = mui_diag_refresh(h)
            let _o = mui_outline_refresh(h)
          }
        } else if rail_util == 1 {
          let opened = mui_ai_open(h)
          if opened == 1 { ai_focus = true } else { ai_focus = false }
        } else if rail_util == 2 {
          let _s = mui_settings_open(h)
          settings_open = true
        } else if explorer_hit == 1 {
          // Explorer header: New File -> a fresh untitled tab, focused for typing.
          let ni = mui_tab_new_untitled(h)
          let _b = mui_ed_tab_switch(h, ni)
          mui_ed_undo_reset(h)
          find_nav = false
        } else if explorer_hit == 2 {
          // Explorer header: New Folder -> prompt for the name (created under the
          // workspace root, then the tree refreshes).
          mui_prompt_open(h, prompt_new_folder())
          prompt_kind = prompt_new_folder()
          find_nav = false
        } else if explorer_hit == 3 {
          // Explorer header: Collapse all expanded folders in the tree.
          mui_tree_collapse_all(h)
        } else if topbar_act == 2 {
          // Top-right more-actions (⋯) button: open the command palette.
          mui_palette_open(h)
          palette_open = true
        } else if ai_click == 2 {
          let _s = mui_ai_send(h)
          ai_focus = true
          typing = false
        } else if ai_click == 1 {
          ai_focus = true
          typing = false
        } else if rail_hit == rail_agents() {
          // Agents (sparkles) icon: toggle the AI copilot panel + focus it.
          let opened = mui_ai_open(h)
          if opened == 1 { ai_focus = true } else { ai_focus = false }
        } else if rail_hit == rail_run() || topbar_act == 1 {
          // Run (play) icon OR the top-right run ▶ button: toggle the Run panel;
          // running the file starts it.
          let opened = mui_run_toggle(h)
          if opened == 1 {
            run_focus = true
            if mui_run_running(h) == 0 { let _r = mui_run_start(h) }
          } else {
            run_focus = false
          }
        } else if rail_hit == rail_debug() {
          // Debug (bug) icon: switch the sidebar to the Run-and-Debug view.
          let _p = mui_panel_set(h, panel_debug())
        } else if rail_hit == rail_test() {
          // Testing (beaker) icon: switch the sidebar to the Testing view + focus.
          let _p = mui_panel_set(h, panel_test())
          test_focus = true
        } else if rail_hit == rail_agents_mty() {
          // Mighty Agents (nodes) icon: switch to the topology view + rescan.
          let _p = mui_panel_set(h, panel_agents_mty())
          let _a = mui_agents_refresh(h)
        } else if rail_hit >= 0 {
          let _p = mui_panel_set(h, rail_hit)
          if rail_hit == panel_scm() {
            let _s = mui_scm_refresh(h)
          } else if rail_hit == panel_search() {
            let _q = mui_search_query_len(h)
          } else if rail_hit == panel_outline() {
            let _o = mui_outline_refresh(h)
          }
        } else if tab_close_hit >= 0 {
          let a = mui_tab_close(h, tab_close_hit)
          let _b = mui_ed_tab_switch(h, a)
          mui_ed_undo_reset(h)
          find_nav = false
          let _r = mui_diag_refresh(h)
          let _o = mui_outline_refresh(h)
        } else if tab_hit >= 0 {
          let cur_active = mui_tab_active(h)
          if tab_hit != cur_active {
            let _b = mui_ed_tab_switch(h, tab_hit)
            mui_ed_undo_reset(h)
            find_nav = false
            let _r = mui_diag_refresh(h)
            let _o = mui_outline_refresh(h)
          }
        } else if cur_panel == panel_agents_mty() {
          // Mighty Agents panel: header "Run" affordance runs the active file;
          // a topology row click jumps to the agent/protocol/handler/tool def.
          let is_run = mui_agents_click_is_run(h)
          if is_run == 1 {
            let _r = mui_agents_run(h)
          } else {
            let a_hit = mui_agents_row_at_click(h)
            if a_hit >= 0 {
              let _j = mui_agents_open_node(h, a_hit)
              typing = false
            }
          }
        } else if cur_panel == panel_outline() {
          // Outline panel: click a symbol row to jump the editor to it.
          let o_hit = mui_outline_row_at_click(h)
          if o_hit >= 0 {
            let _j = mui_outline_open_row(h, o_hit)
            typing = false
          }
        } else if cur_panel == panel_debug() {
          // Debug view: a toolbar button (continue/step/stop) or a call-stack
          // frame row. The shim encodes toolbar hits as >= dbg_toolbar_base().
          let d_hit = mui_dbg_click(h)
          if d_hit >= dbg_toolbar_base() {
            mui_dbg_toolbar_action(h, d_hit)
          } else if d_hit >= 0 {
            // Select the frame -> updates variables + the editor jump target.
            let fline = mui_dbg_select_frame(h, d_hit)
            if fline >= 0 {
              if mui_dbg_cur_file_matches(h) == 1 {
                mui_ed_move_to(h, fline, 0)
              }
            }
          }
        } else if cur_panel == panel_test() {
          // Testing view: a toolbar button (Run/Stop) or a result row click.
          let tb_hit = mui_test_toolbar_at_click(h)
          if tb_hit == test_tb_run() {
            let _r = mui_test_run(h)
            test_focus = true
          } else if tb_hit == test_tb_stop() {
            mui_test_stop(h)
          } else {
            let trow = mui_test_row_at_click(h)
            if trow >= 0 {
              let ok = mui_test_open_row(h, trow)
              if ok == 1 {
                let newtab = mui_test_click_tab(h)
                if newtab >= 0 {
                  let _b = mui_ed_tab_switch(h, newtab)
                  mui_ed_undo_reset(h)
                  let tl = mui_test_click_line(h)
                  let tc = mui_test_click_col(h)
                  if tl >= 0 { mui_ed_move_to(h, tl, tc) }
                  let _r = mui_diag_refresh(h)
                }
              }
            }
          }
        } else if cur_panel == panel_scm() {
          // Source Control panel: header actions (commit/pull/push/fetch) first,
          // then stage/unstage (right-edge action button) or — on the row body —
          // open the file as a tab AND show its inline diff.
          let scm_act = mui_scm_header_action_at_click(h)
          let scm_hit = mui_scm_row_at_click(h)
          if scm_act > 0 {
            if scm_act == 1 {
              let _c = mui_scm_commit(h)
            } else if scm_act == 2 {
              let _pl = mui_git_pull(h)
            } else if scm_act == 3 {
              let _ps = mui_git_push(h)
            } else if scm_act == 4 {
              let _ft = mui_git_fetch(h)
            }
          } else if scm_hit >= 0 {
            let is_stage = mui_scm_click_is_stage(h)
            if is_stage == 1 {
              let _t = mui_scm_toggle_stage(h, scm_hit)
            } else {
              let newidx = mui_scm_open_row(h, scm_hit)
              if newidx >= 0 {
                let _b = mui_ed_tab_switch(h, newidx)
                mui_ed_undo_reset(h)
                find_nav = false
                let _r = mui_diag_refresh(h)
              }
              // Open the inline diff for the clicked file (worktree side, with a
              // staged fallback). Read-only; Escape returns to editing.
              let dok = mui_diff_open_row(h, scm_hit)
              if dok == 1 { diff_open = true }
            }
          }
        } else if cur_panel == panel_search() {
          // Search panel: open the file at the clicked match.
          let s_hit = mui_search_row_at_click(h)
          if s_hit >= 0 {
            let newidx = mui_search_open(h, s_hit)
            if newidx >= 0 {
              let _b = mui_ed_tab_switch(h, newidx)
              mui_ed_undo_reset(h)
              find_nav = false
              let _r = mui_diag_refresh(h)
            }
          }
        } else if mui_tree_row_at_click(h) >= 0 {
          let tree_hit = mui_tree_row_at_click(h)
          let isdir = mui_tree_is_dir(h, tree_hit)
          if isdir == 1 {
            let _c = mui_tree_toggle(h, tree_hit)
          } else if isdir == 0 {
            let newidx = mui_tree_open_row(h, tree_hit)
            if newidx >= 0 {
              let _b = mui_ed_tab_switch(h, newidx)
              mui_ed_undo_reset(h)
              find_nav = false
              let _r = mui_diag_refresh(h)
              let _o = mui_outline_refresh(h)
              mui_qo_record_active(h)
            }
          }
        } else {
          // A click on a pinned sticky header jumps to that scope's line (the
          // sticky band overlays the top editor rows, so it takes priority).
          let sticky_hit = mui_sticky_click(h)
          if sticky_hit >= 0 {
            mui_ghost_dismiss(h)
            mui_ed_move_to(h, sticky_hit, 0)
            first = scroll_to_cursor(first, sticky_hit, rows_i)
            if first < 0 { first = 0 }
            mui_ed_set_scroll(h, first)
            typing = false
            find_nav = false
          } else {
            // Editor body. The quick-fix lightbulb (when shown in the gutter) is
            // hit-tested first: a click on it opens the code-action menu at the
            // bulb's line (same path as Ctrl+.). Otherwise a gutter click toggles
            // a breakpoint, and a body click places the cursor.
            let total_g = mui_ed_line_count(h)
            let bulb_hit = mui_lightbulb_click(h)
            let gline = mui_bp_gutter_click(h, first, total_g)
            if bulb_hit == 1 {
              let lb_l = mui_lightbulb_line(h)
              if lb_l >= 0 {
                mui_ed_move_to(h, lb_l, 0)
                let cnt = mui_codeaction_request(h, lb_l, 0)
                if cnt > 0 {
                  code_action_open = true
                  ca_line = lb_l
                  ca_col = 0
                } else {
                  mui_codeaction_cancel(h)
                }
              }
              typing = false
            } else if gline >= 0 {
              let _b = mui_bp_toggle(h, gline)
            } else {
              mui_ghost_dismiss(h)                             // click moves cursor: ghost stale
              // Split editor: a click first focuses the pane it landed in (the
              // shim rebinds the active tab + per-pane scroll); no-op when unsplit.
              let _pf = mui_pane_focus_at_click(h)
              let cmods = mui_event_mods(h)
              if alt_held(cmods) {                             // Alt+Click : toggle a caret
                mui_ed_toggle_caret_click(h)
              } else {
                let _l = mui_ed_click(h)                       // plain click: place the single caret
              }
              typing = false
              // Clicking into the editor body restores editor keyboard focus:
              // drop any transient band/panel focus so typing goes to the buffer
              // (previously, after focusing Run/Test/Terminal/AI, keystrokes were
              // trapped there until Escape — an editor click now releases it).
              run_focus = false
              web_focus = false
              test_focus = false
              term_focus = false
              ai_focus = false
            }
          }
        }
      }
      if command_click_id >= 0 {
        let id = command_click_id
        if id == cmd_open_file() {
          let oi = mui_open_file_dialog(h)
          if oi >= 0 {
            let _b = mui_ed_tab_switch(h, oi)
            mui_ed_undo_reset(h)
            find_nav = false
            let _r = mui_diag_refresh(h)
            let _o = mui_outline_refresh(h)
            mui_qo_record_active(h)
          } else {
            mui_prompt_open(h, prompt_open())
            prompt_kind = prompt_open()
            find_nav = false
          }
        } else if id == cmd_save() {
          if mui_active_has_path(h) == 0 {
            let sr = mui_save_as_dialog(h)
            if sr == 0 {
              mui_tab_set_dirty(h, mui_tab_active(h), 0)
              let _r = mui_diag_refresh(h)
              let _g = mui_scm_refresh(h)
              let _o = mui_outline_refresh(h)
              let _pr = mui_problems_refresh(h)
            } else {
              mui_prompt_open(h, prompt_save_as())
              prompt_kind = prompt_save_as()
              find_nav = false
            }
          } else {
            let rc = mui_ed_save(h)
            if rc == 0 {
              mui_tab_set_dirty(h, mui_tab_active(h), 0)
              let _r = mui_diag_refresh(h)
              let _g = mui_scm_refresh(h)
              let _o = mui_outline_refresh(h)
              let _pr = mui_problems_refresh(h)
            }
          }
        } else if id == cmd_find() {
          mui_prompt_open(h, prompt_find())
          prompt_kind = prompt_find()
        } else if id == cmd_goto_line() {
          mui_prompt_open(h, prompt_goto())
          prompt_kind = prompt_goto()
          find_nav = false
        } else if id == cmd_goto_definition() {
          prev_line = mui_ed_cursor_line(h)
          prev_col = mui_ed_cursor_col(h)
          go_to_definition(h)
          have_prev = true
          find_nav = false
        } else if id == cmd_hover() {
          let ok = do_hover(h)
          if ok == 1 { hovering = true; hover_line = mui_ed_cursor_line(h); hover_col = mui_ed_cursor_col(h) } else { hovering = false }
        } else if id == cmd_toggle_terminal() {
          if mui_term_is_open(h) == 1 {
            term_focus = true
          } else {
            let ok = mui_term_open(h)
            if ok == 1 { term_focus = true; mui_log_terminal(h) }
          }
        } else if id == cmd_toggle_sidebar() {
          let _s = mui_sidebar_toggle(h)
        } else if id == cmd_next_tab() {
          let a = mui_tab_next(h)
          let _b = mui_ed_tab_switch(h, a)
          mui_ed_undo_reset(h)
          find_nav = false
          let _r = mui_diag_refresh(h)
          let _o = mui_outline_refresh(h)
        } else if id == cmd_prev_tab() {
          let a = mui_tab_prev(h)
          let _b = mui_ed_tab_switch(h, a)
          mui_ed_undo_reset(h)
          find_nav = false
          let _r = mui_diag_refresh(h)
          let _o = mui_outline_refresh(h)
        } else if id == cmd_close_tab() {
          let cur_active = mui_tab_active(h)
          let a = mui_tab_close(h, cur_active)
          let _b = mui_ed_tab_switch(h, a)
          mui_ed_undo_reset(h)
          find_nav = false
          let _r = mui_diag_refresh(h)
          let _o = mui_outline_refresh(h)
        } else if id == cmd_format_document() {
          do_format(h)
        } else if id == cmd_undo() {
          mui_complete_cancel(h)
          completing = false
          find_nav = false
          let _u = mui_ed_undo(h)
        } else if id == cmd_redo() {
          mui_complete_cancel(h)
          completing = false
          find_nav = false
          let _u = mui_ed_redo(h)
        } else if id == cmd_autocomplete() {
          let _c = mui_ed_complete_request(h)
          mui_snippet_inject_completions(h)
          let cnt = mui_complete_count(h)
          if cnt > 0 { completing = true } else { mui_complete_cancel(h) }
        } else if id == cmd_jump_back() {
          if have_prev {
            mui_ed_move_to(h, prev_line, prev_col)
            have_prev = false
            mui_hover_clear(h)
            hovering = false
          }
        } else if id == cmd_quit() {
          running = false
        } else if id == cmd_color_theme() {
          mui_theme_picker_open(h)
          theme_picker_open = true
        } else if id == cmd_run_file() {
          let _r = mui_run_start(h)
          run_focus = true
        } else if id == cmd_settings() {
          let _s = mui_settings_open(h)
          settings_open = true
        } else if id == cmd_run_tests() {
          let _t = mui_test_run(h)
          test_focus = true
        } else if id == cmd_peek_definition() {
          let _p = peek_definition(h)
        } else if id == cmd_welcome() {
          mui_welcome_open(h)
        } else if id == cmd_zen_mode() {
          let _z = mui_zen_toggle(h)
        } else if id == cmd_agents() {
          let _p = mui_panel_set(h, panel_agents_mty())
          let _a = mui_agents_refresh(h)
        } else if id == cmd_run_in_browser() {
          let _w = mui_web_run(h)
          web_focus = true
        } else if id >= cmd_pane_first() && id <= cmd_pane_last() {
          let _pn = mui_pane_dispatch(h, id)
        } else if id >= cmd_git_first() && id <= cmd_git_last() {
          let _g = mui_git_dispatch(h, id)
          if mui_branch_active(h) == 1 { branch_open = true }
        } else if id >= cmd_ws_first() && id <= cmd_ws_last() {
          let wr = mui_ws_dispatch(h, id)
          if wr == 2 {
            mui_prompt_open(h, prompt_open_folder())
            prompt_kind = prompt_open_folder()
            find_nav = false
          } else if wr == 3 {
            if mui_ws_recent_count(h) > 0 {
              // "Open Recent" should let the user choose, not silently open the
              // newest folder. Reuse the Welcome recents surface, which already
              // lists recent files and folders with click targets.
              mui_welcome_open(h)
            } else {
              mui_prompt_open(h, prompt_open_folder())
              prompt_kind = prompt_open_folder()
              find_nav = false
            }
          }
        } else if id >= cmd_fold_first() && id <= cmd_fold_last() {
          let _f = mui_fold_dispatch(h, id)
        } else if id == cmd_keyboard_shortcuts() {
          mui_keys_open(h)
        } else if id == cmd_new_project() {
          mui_prompt_open(h, prompt_new_project())
          prompt_kind = prompt_new_project()
          find_nav = false
        }
      }
      tag = mui_poll_event_s(h)
    }

    // Dismiss the hover popup once the cursor leaves the anchored cell.
    if hovering {
      let cl = mui_ed_cursor_line(h)
      let cc = mui_ed_cursor_col(h)
      if cl != hover_line || cc != hover_col {
        mui_hover_clear(h)
        hovering = false
      }
    }

    // Dismiss the signature popup when the cursor leaves the line it opened on
    // (cursor-move dismiss; ')' / Escape already clear it inline).
    if sig_open {
      let sl = mui_ed_cursor_line(h)
      if sl != sig_line {
        mui_sig_clear(h)
        sig_open = false
      } else {
        sig_col = mui_ed_cursor_col(h)
      }
    }

    // Keep the cursor on-screen, then clamp `first` so we never scroll past EOF.
    let cur_line = mui_ed_cursor_line(h)
    // Track the outline symbol under the cursor (highlights the Outline row +
    // drives the breadcrumb symbol segment). Cheap setter, runs each frame.
    let _osym = mui_outline_set_cursor(h, cur_line)
    first = scroll_to_cursor(first, cur_line, rows_i)
    let total = mui_ed_line_count(h)
    if first + rows_i > total {
      if total > rows_i { first = total - rows_i } else { first = 0 }
    }
    if first < 0 { first = 0 }
    mui_ed_set_scroll(h, first)

    // Sticky scroll: recompute the enclosing-scope headers to pin for this frame
    // from the outline + the (now-current) scroll offset. Mirrors the
    // `sticky_scroll` preference; 0 when not scrolled / disabled / no scope.
    let sticky_n = mui_sticky_count(h)

    // Drain AI stream deltas into the transcript BEFORE the frame so streamed
    // text renders live (returns 1 when the transcript changed).
    let _ai_changed = mui_ai_pump(h)

    // Inline AI ghost-text: fire the debounced request once the idle window has
    // elapsed (tick), then drain any finished completion into the dim ghost
    // overlay (poll). Both no-op when inline AI is disabled / no key is set.
    let _g_fired = mui_ghost_tick(h)
    let _g_ready = mui_ghost_poll(h)

    // Drain Run-panel process output into its line list BEFORE the frame so the
    // streamed stdout/stderr renders live (no-op when the panel is idle/closed).
    if mui_run_active(h) == 1 {
      let _rc = mui_run_pump(h)
    }

    // Drain the Web Playground's `mty serve`/`mty build` output BEFORE the frame;
    // when its pump returns 1 the served URL just became available, so open the
    // default browser exactly once (the interactive browser launch is the user's
    // machine doing its thing — Mighty just fires the open).
    if mui_web_active(h) == 1 {
      let web_url_ready = mui_web_pump(h)
      if web_url_ready == 1 {
        let _ob = mui_web_open_browser(h)
      }
    }

    // Drain `mty test` output into the results tree BEFORE the frame so streamed
    // pass/fail rows render live (only while a test run is in flight).
    if mui_test_running(h) == 1 {
      let _tc = mui_test_pump(h)
    }

    // Drain the Mighty Agents panel's `mty run` output while a run is in flight.
    if mui_agents_running(h) == 1 {
      let _ac = mui_agents_pump(h)
    }

    // Drain DAP adapter events into the debug model BEFORE the frame (stop
    // position, stack, variables). When a fresh stop arrives, jump the editor to
    // the stopped line if it's in the visible file.
    let _dbgc = mui_dbg_pump(h)
    if mui_dbg_take_stopped(h) == 1 {
      let dl = mui_dbg_cur_line(h)
      if dl >= 0 {
        if mui_dbg_cur_file_matches(h) == 1 {
          mui_ed_move_to(h, dl, 0)
        }
      }
    }

    // Drain PTY output into the shim's terminal grid BEFORE the frame.
    let term_on = mui_term_is_open(h)
    if term_on == 1 {
      mui_term_pump(h)
      if mui_term_running(h) == 0 { term_focus = false }
    }

    // Advance toast timers BEFORE drawing so expired cards disappear this frame.
    let _toast_changed = mui_toast_tick(h)

    // Auto-save tick: when the Auto Save pref is ON, save the active file ~1.2s
    // after the last edit (debounced; only real file-backed, dirty tabs). No-op
    // when the pref is OFF or the tab has no path. Returns 1 when a save fired.
    let _autosaved = mui_autosave_tick(h)

    // Quick-fix lightbulb: advance its debounce + (when due) probe the cursor
    // line for code actions. The shim rate-limits the probe so the LSP isn't hit
    // every frame. Returns 1 when the bulb is visible (drawn below, in the gutter).
    let _lightbulb_on = mui_lightbulb_tick(h)

    // Welcome screen replaces the editor body when no file is open (or when
    // forced from the palette). Zen / focus mode hides the rail, sidebar, tab
    // bar, breadcrumb and status bar for a distraction-free full-window editor.
    let welcome_on = mui_welcome_active(h)
    let zen_on = mui_zen_active(h)

    let total_now = mui_ed_line_count(h)
    mui_begin_frame_s(h)
    if welcome_on == 1 {
      // Branded landing in the editor body (brand + recents + quick actions +
      // tips). The chrome (sidebar/rail/tab bar) still frames it unless in Zen.
      mui_welcome_draw(h)
    } else {
      // Draw the editor body (current-line band + gutter + syntax-colored text +
      // selection + caret) shim-side from the AUTHORITATIVE model. Editing is live.
      mui_ed_draw(h, rows_i)
      // Git blame gutter: a dim per-line sha · author · date band over the left
      // gutter. No-op unless toggled on (Alt+B / "Git: Toggle Blame").
      mui_blame_draw(h, rows_i)
      // Inline AI ghost-text overlay: dim suggestion painted at the cursor, over the
      // editor body but under chrome. No-op unless a ghost is currently shown.
      mui_ghost_draw(h)
      // Inline git diff view: when open it paints over the editor body (read-only).
      // No-op unless active, so calling it unconditionally is safe.
      mui_diff_draw(h)
      // Debugger gutter decorations: breakpoint dots + the stopped-line band +
      // current-instruction arrow. No-op when there are no breakpoints / no stop.
      mui_dbg_draw(h, first, rows_i, total_now)
      if find_nav { draw_find_highlights(h, total_now, first, rows_i) }
      draw_diagnostics(h, total_now, first, rows_i)
      // Quick-fix lightbulb: a gutter bulb on the cursor line when it has code
      // actions (visibility computed by the debounced tick above). Drawn after
      // diagnostics so it reads as the actionable affordance on a fixable line.
      if mui_lightbulb_visible(h) == 1 {
        let lb_line = mui_lightbulb_line(h)
        if lb_line >= first && lb_line < first + rows_i {
          mui_lightbulb_draw(h, lb_line - first, total_now)
        }
      }
      // Sticky scroll: pin the enclosing-scope headers as an elevated band at the
      // top of the editor body (over the scrolling code, under the chrome). No-op
      // when nothing is pinned (not scrolled / disabled). Suppressed under the diff
      // view (it owns the body region) and under Zen mode.
      if mui_diff_active(h) == 0 && zen_on == 0 { mui_sticky_draw(h, 0) }
    }
    // The breadcrumb shares the band the inline-diff header occupies; suppress it
    // while the diff view is active so it doesn't faintly render over the header,
    // on the Welcome screen, and in Zen mode.
    if mui_diff_active(h) == 0 && welcome_on == 0 && zen_on == 0 { mui_breadcrumb_draw(h) }
    // Status bar: hidden in Zen mode (distraction-free).
    if zen_on == 0 { draw_status_bar(h) }
    // The sidebar shows the active panel: Explorer (file tree), Search, or
    // Source Control. Each draw is a no-op unless its panel is active. Hidden in
    // Zen mode.
    if zen_on == 0 {
      let cur_panel_draw = mui_panel_active(h)
      if cur_panel_draw == panel_search() {
        mui_search_draw(h)
      } else if cur_panel_draw == panel_scm() {
        mui_scm_draw(h)
      } else if cur_panel_draw == panel_outline() {
        mui_outline_draw(h)
      } else if cur_panel_draw == panel_debug() {
        mui_dbg_view_draw(h)
      } else if cur_panel_draw == panel_test() {
        mui_test_draw(h)
      } else if cur_panel_draw == panel_agents_mty() {
        mui_agents_draw(h)
      } else {
        mui_sidebar_draw(h)
      }
      mui_rail_draw(h)
      mui_tab_bar_draw(h)
    }
    // AI copilot panel (right-docked); no-op unless open. Drawn over the body so
    // its surface occludes the editor, but under transient overlays below.
    mui_ai_draw(h)
    if term_on == 1 { mui_term_draw(h) }
    // Run panel: a lower band (header + status + scrollable output). No-op unless
    // open, so calling it unconditionally also lets the screenshot hook render it.
    mui_run_draw(h)
    // Web Playground: the same lower band (globe header + URL pill + Stop +
    // scrollable serve/build output). No-op unless open; calling it
    // unconditionally also lets the MUI_WEB_AUTOOPEN screenshot hook render it.
    mui_web_draw(h)
    // Problems panel: a bottom dock (header with error/warning totals + grouped
    // rows). No-op unless open, so calling it unconditionally also lets the
    // MUI_PROBLEMS_AUTOOPEN screenshot hook render it.
    mui_problems_draw(h)
    // Window controls (min/max/close + run/⋯) drawn as a LATE pass — after every
    // docked panel — so a right-docked panel (AI copilot) can never occlude them.
    // Hidden in Zen mode (which hides all chrome). Clicks: min/max/close are
    // intercepted shim-side; run/⋯ route through `mui_topbar_action_at_click`.
    if zen_on == 0 { mui_window_controls_draw(h) }
    // Interactive breadcrumb dropdown (folder files / document symbols). No-op
    // unless active; the MUI_BREADCRUMB_AUTOOPEN hook renders it for capture.
    mui_crumb_menu_draw(h)
    if prompt_kind != 0 { mui_prompt_draw(h) }
    // Replace bar no-ops unless active, so calling it unconditionally also lets
    // the MUI_REPLACE_AUTOOPEN screenshot hook render it without a keystroke.
    mui_replace_draw(h)
    // autocomplete dropdown near the cursor (drawn over the body).
    if completing {
      let c_line = mui_ed_cursor_line(h)
      let c_col = mui_ed_cursor_col(h)
      if c_line >= first && c_line < first + rows_i {
        mui_complete_draw_at(h, c_line - first, c_col, total_now)
      }
    }
    // hover popup near the anchored cell.
    if hovering {
      if hover_line >= first && hover_line < first + rows_i {
        mui_hover_draw(h, hover_line - first, hover_col, total_now)
      }
    }
    // signature-help popup ABOVE the cursor cell it opened at.
    if sig_open {
      if sig_line >= first && sig_line < first + rows_i {
        mui_sig_draw(h, sig_line - first, sig_col, total_now)
      }
    }
    // code-action menu near the cursor cell it opened at.
    if code_action_open {
      if ca_line >= first && ca_line < first + rows_i {
        mui_codeaction_draw(h, ca_line - first, ca_col, total_now)
      }
    }
    // rename inline input: a centered card (drawn over the body when active).
    if renaming { mui_rename_draw(h) }
    // Peek definition: an inline framed card below the cursor line. No-op unless
    // active, so calling it unconditionally also lets the MUI_PEEK_AUTOOPEN
    // screenshot hook render it without a keystroke.
    mui_peek_draw(h, first, rows_i)
    // command palette: a centered overlay (no-ops unless active, so the
    // MUI_PALETTE_AUTOOPEN screenshot hook renders it without a keystroke).
    mui_palette_draw(h)
    // universal Quick-Open: a centered overlay (no-ops unless active, so the
    // MUI_QUICKOPEN_AUTOOPEN screenshot hook renders it without a keystroke).
    mui_qo_draw(h)
    // color-theme picker: a centered overlay (no-ops unless active, so the
    // MUI_THEMEPICKER_AUTOOPEN screenshot hook renders it without a keystroke).
    mui_theme_picker_draw(h)
    // Settings panel: a centered overlay (no-ops unless active, so the
    // MUI_SETTINGS_AUTOOPEN screenshot hook renders it without a keystroke).
    mui_settings_draw(h)
    // Branch switcher: a centered overlay (no-ops unless active, so the
    // MUI_BRANCH_AUTOOPEN screenshot hook renders it without a keystroke).
    mui_branch_draw(h)
    // Keyboard Shortcuts overlay: a centered overlay (no-ops unless active, so
    // the MUI_SHORTCUTS_AUTOOPEN screenshot hook renders it without a keystroke).
    mui_keys_draw(h)
    // Toast notifications: the TOP of the overlay order so transient cards sit
    // above every panel/overlay. No-op when the queue is empty.
    mui_toast_draw(h)
    mui_end_frame_s(h)

    frame = frame + 1
    // Only self-terminate in headless/screenshot/probe mode (headless_limit > 0).
    // A normal run keeps headless_limit == 0 and loops until the window Close
    // event flips `running` to false (handled in the poll arm above).
    if headless_limit > 0 && frame >= headless_limit { running = false }
  }

  log("mighty-ide: shutting down")
  mui_shutdown_s(h)
  log("mighty-ide: done")
}

// ---- shared action helpers (single shim-call actions factor cleanly, L27) ----

// Signature help at the cursor: request over the live model. Returns 1 if a
// signature is available (the shim reads the model text itself, no streaming).
fn do_signature_help(h: I64) -> I32 {
  let line = mui_ed_cursor_line(h)
  let col = mui_ed_cursor_col(h)
  mui_sig_request(h, line, col)
}

// Hover at the cursor: stream the model, request hover. Returns 1 if available.
fn do_hover(h: I64) -> I32 {
  mui_ed_nav_stream(h)
  let line = mui_ed_cursor_line(h)
  let col = mui_ed_cursor_col(h)
  mui_hover_request(h, line, col)
}

// Go-to-definition at the cursor. Moves the cursor in place (same file) or opens
// the target file as a tab and jumps. The shim owns the resolved target.
fn go_to_definition(h: I64) {
  mui_ed_nav_stream(h)
  let line = mui_ed_cursor_line(h)
  let col = mui_ed_cursor_col(h)
  let found = mui_def_request(h, line, col)
  if found == 1 {
    mui_hover_clear(h)
    let same = mui_def_path_matches_current(h)
    let tl = mui_def_target_line(h)
    let tc = mui_def_target_col(h)
    if same == 1 {
      if tl >= 0 { mui_ed_move_to(h, tl, tc) }
    } else {
      let newidx = mui_def_open_target(h)
      if newidx >= 0 {
        let _b = mui_ed_tab_switch(h, newidx)
        mui_ed_undo_reset(h)
        if tl >= 0 { mui_ed_move_to(h, tl, tc) }
        let _r = mui_diag_refresh(h)
      }
    }
  }
}

// Peek definition at the cursor: resolve the def (reusing the nav request) and
// open the inline peek card below the current line. Returns 1 if a definition
// was found + previewed, else 0 (a graceful no-op / "no definition").
fn peek_definition(h: I64) -> I32 {
  mui_ed_nav_stream(h)
  let line = mui_ed_cursor_line(h)
  let col = mui_ed_cursor_col(h)
  mui_peek_open(h, line, col)
}

// Format the active document in place: save -> checkpoint -> `mty fmt` -> reload
// (only on success). The save+reload keeps the model authoritative; the undo
// checkpoint makes the format reversible in one Ctrl+Z.
fn do_format(h: I64) {
  let active = mui_tab_active(h)
  let rc = mui_ed_save(h)
  if rc == 0 {
    mui_tab_set_dirty(h, active, 0)
    // Checkpoint the pre-format model so the whole format is one Ctrl+Z. Keep
    // the checkpoint (no reset) after reload so undo can restore it.
    mui_ed_undo_record(h)
    let ok = mui_format_current(h)
    if ok == 1 {
      let _n = mui_ed_load(h)
      let _r = mui_diag_refresh(h)
    }
  }
}
